# Cloudflare Pages response headers for the public ResearchOps site.
# HTML remains uncached so page changes and route fixes are visible immediately.
# Static assets are cached at the edge and revalidated by the browser.

/*.html
	Cache-Control: no-store
	X-Content-Type-Options: nosniff

/
	Cache-Control: no-store
	X-Content-Type-Options: nosniff

/css/*
	Cache-Control: public, max-age=3600, stale-while-revalidate=86400
	X-Content-Type-Options: nosniff

/js/*
	Cache-Control: public, max-age=3600, stale-while-revalidate=86400
	X-Content-Type-Options: nosniff

/components/*
	Cache-Control: public, max-age=3600, stale-while-revalidate=86400
	X-Content-Type-Options: nosniff

/partials/*
	Cache-Control: public, max-age=3600, stale-while-revalidate=86400
	X-Content-Type-Options: nosniff

/*.svg
	Cache-Control: public, max-age=3600, stale-while-revalidate=86400
	X-Content-Type-Options: nosniff

/*.png
	Cache-Control: public, max-age=3600, stale-while-revalidate=86400
	X-Content-Type-Options: nosniff

/*.jpg
	Cache-Control: public, max-age=3600, stale-while-revalidate=86400
	X-Content-Type-Options: nosniff

/*.jpeg
	Cache-Control: public, max-age=3600, stale-while-revalidate=86400
	X-Content-Type-Options: nosniff

/*.webp
	Cache-Control: public, max-age=3600, stale-while-revalidate=86400
	X-Content-Type-Options: nosniff

/*.woff
	Cache-Control: public, max-age=86400, stale-while-revalidate=604800
	X-Content-Type-Options: nosniff

/*.woff2
	Cache-Control: public, max-age=86400, stale-while-revalidate=604800
	X-Content-Type-Options: nosniff
