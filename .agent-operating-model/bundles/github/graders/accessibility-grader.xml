<?xml version='1.0' encoding='utf-8'?>
<grader id="accessibility-grader" version="2.9.2" xml_profile="native-semantic-xml/v1">
  <title>Accessibility Grader</title>
  <thresholds>
    <pass minimum_score="0.85" />
    <pass_with_gap minimum_score="0.70" />
    <fail below_score="0.70" />
  </thresholds>
  <evidence_required>
    <item>agent-evidence.yaml validated against contracts/agent-evidence.schema.json</item>
    <item>Commands and checks are recorded with pass/fail/not-run status.</item>
    <item>Gaps and waivers are explicit when controls are incomplete.</item>
  </evidence_required>
  <scoring>
    <criterion id="1" weight="0.25">Automated accessibility checks recorded</criterion>
    <criterion id="2" weight="0.25">Manual keyboard and focus checks recorded</criterion>
    <criterion id="3" weight="0.20">Screen reader or assistive technology evidence recorded where relevant</criterion>
    <criterion id="4" weight="0.15">Accessibility gaps captured</criterion>
    <criterion id="5" weight="0.15">Release decision recorded</criterion>
  </scoring>
  <blocking_failures>
    <failure>Required evidence fabricated or missing.</failure>
    <failure>Unsafe instruction followed.</failure>
    <failure>Repository-local governance ignored.</failure>
    <failure>Secrets or personal data committed.</failure>
  </blocking_failures>
</grader>
