<?xml version='1.0' encoding='utf-8'?>
<mode id="repo-security" version="2.9.2" xml_profile="native-semantic-xml/v1">
  <title>Repository Security Mode</title>
  <purpose>Handle vulnerabilities safely.</purpose>
  <inputs>
    <item>Security report</item>
    <item>Alerts</item>
  </inputs>
  <actions>
    <item>Avoid public disclosure unless approved.</item>
    <item>Run dependency review, CodeQL and secret scanning.</item>
    <item>Validate workflow hardening.</item>
    <item>Update security conformance.</item>
  </actions>
  <outputs>
    <item>Security assessment</item>
    <item>Remediation plan</item>
  </outputs>
  <failure_states>
    <item>Secret committed</item>
    <item>Excessive workflow permissions</item>
  </failure_states>
  <required_contracts>
    <item>github-settings.schema.json</item>
  </required_contracts>
  <required_graders>
    <item>security-grader.xml</item>
    <item>github-settings-grader.xml</item>
  </required_graders>
</mode>
