<?xml version='1.0' encoding='utf-8'?>
<mode id="repo-discovery" version="2.9.2" xml_profile="native-semantic-xml/v1">
  <title>Repository Discovery Mode</title>
  <purpose>Build verified understanding before changes.</purpose>
  <inputs>
    <item>User task</item>
    <item>Repository tree</item>
    <item>Root docs</item>
  </inputs>
  <actions>
    <item>Read README, CONTRIBUTING, SECURITY, CODEOWNERS, licence, AGENTS and RECENT_LEARNINGS.</item>
    <item>Inspect manifests, lockfiles and workflows.</item>
    <item>Classify archetype, language stack, risk and governance.</item>
    <item>Record unknowns in gap register.</item>
  </actions>
  <outputs>
    <item>Discovery summary</item>
    <item>Classification</item>
    <item>Gaps</item>
  </outputs>
  <failure_states>
    <item>Instructions not read</item>
    <item>Stack guessed</item>
  </failure_states>
  <required_contracts>
    <item>repository-contract.schema.json</item>
    <item>gap-register.schema.json</item>
  </required_contracts>
  <required_graders>
    <item>discovery-grader.xml</item>
  </required_graders>
</mode>
