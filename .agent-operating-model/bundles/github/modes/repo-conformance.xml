<?xml version='1.0' encoding='utf-8'?>
<mode id="repo-conformance" version="2.9.3" xml_profile="native-semantic-xml/v1">
  <title>Repository Conformance Mode</title>
  <purpose>Audit repository against bundle controls.</purpose>
  <inputs>
    <item>Repository tree</item>
  </inputs>
  <actions>
    <item>Validate bundle and registry.</item>
    <item>Audit files, workflows and settings.</item>
    <item>Update conformance matrix and gap register.</item>
    <item>Create harm register when ethics triggers are met.</item>
  </actions>
  <outputs>
    <item>Conformance matrix</item>
    <item>Gap register</item>
  </outputs>
  <failure_states>
    <item>Gaps hidden</item>
  </failure_states>
  <required_contracts>
    <item>conformance-record.schema.json</item>
    <item>gap-register.schema.json</item>
  </required_contracts>
  <required_graders>
    <item>conformance-grader.xml</item>
  </required_graders>
</mode>
