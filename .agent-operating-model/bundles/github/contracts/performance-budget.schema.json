{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Performance Budget",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "budgets"
  ],
  "properties": {
    "budgets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric",
          "threshold",
          "tolerance_percent"
        ],
        "properties": {
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "threshold": {
            "type": "number"
          },
          "tolerance_percent": {
            "type": "number",
            "minimum": 0
          },
          "unit": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "blocking",
              "advisory"
            ]
          }
        }
      }
    }
  }
}
