{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SBOM Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "path",
    "subject",
    "generated_by"
  ],
  "properties": {
    "format": {
      "type": "string",
      "enum": [
        "CycloneDX-JSON",
        "SPDX-JSON",
        "SPDX-TAG-VALUE"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "attested": {
      "type": "boolean"
    }
  }
}
