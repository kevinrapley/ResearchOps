{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "permissions",
    "jobs"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "permissions": {
      "type": "object"
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
