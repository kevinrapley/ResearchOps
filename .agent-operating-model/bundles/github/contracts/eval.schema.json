{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Eval",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "prompt",
    "fixture_repo",
    "expected_files",
    "graders",
    "minimum_score",
    "blocking_failures"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "fixture_repo": {
      "type": "string",
      "minLength": 1
    },
    "expected_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_changed_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "graders": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "minimum_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "blocking_failures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
