{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Grade Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "grader_id",
    "score",
    "decision",
    "blocking_failures",
    "evidence",
    "deductions"
  ],
  "properties": {
    "grader_id": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "pass",
        "pass_with_gap",
        "fail"
      ]
    },
    "blocking_failures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deductions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
