{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Harm Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "harms"
  ],
  "properties": {
    "harms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "harm",
          "affected_groups",
          "likelihood",
          "severity",
          "mitigation",
          "residual_risk",
          "owner",
          "escalation_route",
          "release_decision"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^HARM-[0-9]{3,}$"
          },
          "harm": {
            "type": "string",
            "minLength": 1
          },
          "affected_groups": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "likelihood": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "mitigation": {
            "type": "string",
            "minLength": 1
          },
          "residual_risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "escalation_route": {
            "type": "string",
            "minLength": 1
          },
          "release_decision": {
            "type": "string",
            "enum": [
              "acceptable",
              "acceptable-with-controls",
              "blocked",
              "requires-escalation"
            ]
          }
        }
      }
    }
  }
}
