{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Repository Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "archetype",
    "owners",
    "license",
    "risk_level",
    "quality_gates"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "archetype": {
      "type": "string",
      "minLength": 1
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "type": "string",
      "minLength": 1
    },
    "quality_gates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
