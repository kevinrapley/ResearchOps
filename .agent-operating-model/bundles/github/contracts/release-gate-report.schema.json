{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Release Gate Report",
  "type": "object",
  "required": [
    "gate",
    "mode",
    "status",
    "started_at_unix",
    "duration_seconds",
    "commands"
  ],
  "additionalProperties": true,
  "properties": {
    "gate": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "running",
        "passed",
        "failed"
      ]
    },
    "started_at_unix": {
      "type": "integer"
    },
    "duration_seconds": {
      "type": "number"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "status",
          "duration_seconds",
          "stdout_tail",
          "stderr_tail"
        ],
        "additionalProperties": true,
        "properties": {
          "command": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "timeout",
              "unknown"
            ]
          },
          "duration_seconds": {
            "type": "number"
          },
          "stdout_tail": {
            "type": "string"
          },
          "stderr_tail": {
            "type": "string"
          },
          "returncode": {
            "type": [
              "integer",
              "null"
            ]
          },
          "error": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      }
    },
    "failed_command": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "error": {
      "type": [
        "object",
        "null"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        }
      },
      "then": {
        "required": [
          "failed_command",
          "error"
        ]
      }
    }
  ]
}