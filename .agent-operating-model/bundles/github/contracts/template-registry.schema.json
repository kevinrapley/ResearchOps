{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Template Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "templates"
  ],
  "properties": {
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "template_path",
          "destination_path",
          "required_for",
          "archetypes",
          "trigger_conditions",
          "associated_contract",
          "associated_graders",
          "copy_mode",
          "required"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "template_path": {
            "type": "string",
            "minLength": 1
          },
          "destination_path": {
            "type": "string",
            "minLength": 1
          },
          "required_for": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "archetypes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "trigger_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "associated_contract": {
            "type": [
              "string",
              "null"
            ]
          },
          "associated_graders": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "copy_mode": {
            "type": "string",
            "enum": [
              "copy",
              "render",
              "reference"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          },
          "required_status_check": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}