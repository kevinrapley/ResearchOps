{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenAI Bundle Variables",
  "type": "object",
  "properties": {
    "user_request": { "type": "string" },
    "openai_products": { "type": "array", "items": { "type": "string" } },
    "model_family": { "type": ["string", "null"] },
    "high_stakes": { "type": "boolean" },
    "deployment_environment": { "type": ["string", "null"] }
  },
  "required": ["user_request"]
}
