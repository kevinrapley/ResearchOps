<?xml version="1.0" encoding="utf-8"?>
<template_module id="structured-output-contract" version="1.0.0">
  <title>Structured Output Contract Template</title>
  <template_block name="contract" title="Contract">
    <checklist ordered="false">
      <entry level="0">JSON schema identifier and version.</entry>
      <entry level="0">Required fields and allowed enums.</entry>
      <entry level="0">Refusal and incomplete-output handling.</entry>
      <entry level="0">Application-level validation beyond schema conformance.</entry>
      <entry level="0">Fallback when model output fails validation.</entry>
      <entry level="0">Human-review trigger conditions.</entry>
    </checklist>
  </template_block>
</template_module>
