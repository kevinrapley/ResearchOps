{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenAI Bundle Gap Register",
  "type": "object",
  "additionalProperties": false,
  "required": ["gaps"],
  "properties": {
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "area", "description", "source_status", "risk", "next_action"],
        "properties": {
          "id": { "type": "string" },
          "area": { "type": "string" },
          "description": { "type": "string" },
          "source_status": { "type": "string", "enum": ["not-covered", "partially-covered", "stale-risk", "needs-verification"] },
          "risk": { "type": "string", "enum": ["low", "medium", "high"] },
          "next_action": { "type": "string" }
        }
      }
    }
  }
}
