{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenAI Grader Output",
  "type": "object",
  "properties": {
    "grader_id": { "type": "string" },
    "label": { "type": "string", "enum": ["pass", "pass_with_notes", "fail_revise", "fail_escalate"] },
    "explanation": { "type": "string" }
  },
  "required": ["grader_id", "label", "explanation"]
}
