{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchops.local/schemas/researchops-developer-control-grade.schema.json",
  "title": "ResearchOps Developer Control Grade",
  "type": "object",
  "required": ["score", "decision", "checks"],
  "properties": {
    "score": {"type": "number", "minimum": 0, "maximum": 1},
    "decision": {"type": "string", "enum": ["pass", "warn", "fail"]},
    "checks": {
      "type": "object",
      "properties": {
        "repo_inspection": {"type": "boolean"},
        "component_routing": {"type": "boolean"},
        "route_contracts": {"type": "boolean"},
        "visual_walkthrough": {"type": "boolean"},
        "ci_governance": {"type": "boolean"},
        "accessibility": {"type": "boolean"},
        "ethics": {"type": "boolean"},
        "performance": {"type": "boolean"},
        "validation": {"type": "boolean"}
      }
    },
    "findings": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"type": "string"}}
  }
}
