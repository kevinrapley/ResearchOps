<?xml version="1.0" encoding="UTF-8"?>
<reference id="researchops-endpoint-catalog" version="1.13.0">
  <purpose>Lists canonical ResearchOps endpoint families.</purpose>
  <endpoints>
    <endpoint method="GET" path="/api/_diag/ping" response_file="examples/diagnostics/ping.response.json" />
    <endpoint method="GET" path="/api/health" response_file="examples/diagnostics/health.response.json" />
    <endpoint method="GET" path="/api/projects" response_file="examples/projects/list.response.json" />
    <endpoint method="POST" path="/api/projects" request_file="examples/projects/create.request.json" response_file="examples/projects/create.response.json" />
    <endpoint method="GET" path="/api/studies" response_file="examples/studies/list.response.json" />
    <endpoint method="POST" path="/api/studies" request_file="examples/studies/create.request.json" response_file="examples/studies/create.response.json" />
    <endpoint method="GET" path="/api/participants" response_file="examples/participants/list.response.json" />
    <endpoint method="GET" path="/api/sessions" response_file="examples/sessions/list.response.json" />
    <endpoint method="GET" path="/api/guides" response_file="examples/guides/list.response.json" />
    <endpoint method="GET" path="/api/journal-entries" response_file="examples/journals/list.response.json" />
  </endpoints>
</reference>
