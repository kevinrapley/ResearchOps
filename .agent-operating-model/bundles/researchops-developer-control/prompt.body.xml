<?xml version="1.0" encoding="utf-8"?>
<prompt_bundle id="researchops-developer-control" version="1.13.0" default_mode="rops-build" xml_profile="native-semantic-xml/v1">
  <bundle_identity>
    <name>ResearchOps Developer-Control Prompt Bundle</name>
    <description>Project-specific prompt bundle for building, reviewing, operating, and patterning the ResearchOps platform with concrete implementation contracts, metadata and ethics controls, contract-test packs, regression-test formatting governance, performance audit doctrine, CSS ownership controls, and CI ordering controls.</description>
    <status>gold-standard-project-bundle</status>
  </bundle_identity>

  <instruction_hierarchy>
    <authority_order>
      <authority>law-regulation-and-platform-safety</authority>
      <authority>privacy-security-and-data-minimisation</authority>
      <authority>accessibility-and-inclusive-research-obligations</authority>
      <authority>ResearchOps-domain-model-and-user-need</authority>
      <authority>repository-contract-and-existing-architecture</authority>
      <authority>GOVUK-patterns-and-product-contracts</authority>
      <authority>API-contract-and-integration-contracts</authority>
      <authority>test-quality-and-release-gates</authority>
      <authority>performance-and-loading-contracts</authority>
      <authority>human-accountability-and-governance</authority>
      <authority>user-format-and-delivery-preferences</authority>
    </authority_order>
  </instruction_hierarchy>

  <runtime_defaults>
    <default_mode>rops-build</default_mode>
    <default_depth>standard</default_depth>
    <phase_changes>human-owned</phase_changes>
    <human_review_required_for_authoritative_use>true</human_review_required_for_authoritative_use>
    <do_not_invent_identifiers>true</do_not_invent_identifiers>
    <do_not_expose_internal_field_names_to_end_users>true</do_not_expose_internal_field_names_to_end_users>
    <repository_grounding_required>true</repository_grounding_required>
  </runtime_defaults>

  <assembly>
    <always_load>references/core-rules.xml</always_load>
    <always_load>references/researchops-platform-context.xml</always_load>
    <always_load>references/developer-control-contract.xml</always_load>
    <always_load>references/implementation-workflow.xml</always_load>
    <always_load>references/quality-gates.xml</always_load>
    <always_load>references/researchops-performance-rules.xml</always_load>
    <always_load>references/integration-contracts.xml</always_load>
    <always_load>references/airtable-api-spec.xml</always_load>
    <always_load>references/mural-api-spec.xml</always_load>
    <always_load>references/cloudflare-development-spec.xml</always_load>
    <always_load>references/govuk-design-system-spec.xml</always_load>
    <always_load>references/researchops-endpoint-catalog.xml</always_load>
    <always_load>references/researchops-repository-conventions.xml</always_load>
    <always_load>references/researchops-design-patterns.xml</always_load>
    <always_load>references/researchops-example-payloads.xml</always_load>
    <always_load>references/researchops-conformance-matrix.xml</always_load>
    <always_load>references/researchops-gap-register.xml</always_load>
    <always_load>references/researchops-contract-test-pack.xml</always_load>
    <always_load>references/researchops-single-record-route-policy.xml</always_load>
    <always_load>references/researchops-route-availability-policy.xml</always_load>
    <always_load>references/researchops-ci-governance-pack.xml</always_load>
    <always_load>references/researchops-joined-proxy-worker-tests.xml</always_load>
    <always_load>references/researchops-conformance-summary-pack.xml</always_load>
    <always_load>references/researchops-fixture-index-validation-pack.xml</always_load>
    <always_load>references/researchops-metadata-provenance-pack.xml</always_load>
    <always_load>references/researchops-ethics-pack.xml</always_load>
    <always_load>references/researchops-pr-and-logging-governance-pack.xml</always_load>
  </assembly>

  <mode_registry>
    <mode_ref id="rops-build" file="modes/rops-build.xml"/>
    <mode_ref id="rops-api" file="modes/rops-api.xml"/>
    <mode_ref id="rops-ui" file="modes/rops-ui.xml"/>
    <mode_ref id="rops-patterns" file="modes/rops-patterns.xml"/>
    <mode_ref id="rops-integration" file="modes/rops-integration.xml"/>
    <mode_ref id="rops-fix" file="modes/rops-fix.xml"/>
    <mode_ref id="rops-review" file="modes/rops-review.xml"/>
    <mode_ref id="rops-conformance" file="modes/rops-conformance.xml"/>
  </mode_registry>

  <role_registry>
    <role_ref id="research-operations" file="roles/research-operations.xml"/>
    <role_ref id="developer" file="roles/developer.xml"/>
    <role_ref id="qa" file="roles/qa.xml"/>
    <role_ref id="security" file="roles/security.xml"/>
    <role_ref id="accessibility" file="roles/accessibility.xml"/>
    <role_ref id="devops" file="roles/devops.xml"/>
    <role_ref id="governance" file="roles/governance.xml"/>
    <role_ref id="metrics" file="roles/metrics.xml"/>
    <role_ref id="user-research" file="roles/user-research.xml"/>
    <role_ref id="product" file="roles/product.xml"/>
    <role_ref id="ethics" file="roles/ethics.xml"/>
  </role_registry>

  <template_registry>
    <template_ref id="task-brief" file="templates/task-brief-template.xml"/>
    <template_ref id="implementation-plan" file="templates/implementation-plan-template.xml"/>
    <template_ref id="api-endpoint" file="templates/api-endpoint-template.xml"/>
    <template_ref id="ui-page" file="templates/ui-page-template.xml"/>
    <template_ref id="adapter-contract" file="templates/adapter-contract-template.xml"/>
    <template_ref id="service-module-contract" file="templates/service-module-contract-template.xml"/>
    <template_ref id="repository-convention" file="templates/repository-convention-template.xml"/>
    <template_ref id="design-pattern-spec" file="templates/design-pattern-spec-template.xml"/>
    <template_ref id="test-plan" file="templates/test-plan-template.xml"/>
    <template_ref id="adr" file="templates/adr-template.xml"/>
    <template_ref id="pr-summary" file="templates/pr-summary-template.xml"/>
    <template_ref id="endpoint-example" file="templates/endpoint-example-template.xml"/>
    <template_ref id="conformance-matrix" file="templates/conformance-matrix-template.xml"/>
    <template_ref id="gap-register" file="templates/gap-register-template.xml"/>
    <template_ref id="contract-test-spec" file="templates/contract-test-spec-template.xml"/>
    <template_ref id="ci-governance" file="templates/ci-governance-template.xml"/>
    <template_ref id="conformance-summary" file="templates/conformance-summary-template.xml"/>
    <template_ref id="metadata-provenance" file="templates/metadata-provenance-template.xml"/>
    <template_ref id="ethics-impact" file="templates/ethics-impact-template.xml"/>
  </template_registry>

  <contracts>
    <inputs ref="variables.schema.json"/>
    <outputs ref="output.schema.json"/>
    <grading ref="grade.schema.json"/>
  </contracts>
</prompt_bundle>
