{
  "suite": "single-record-route-availability",
  "purpose": "Prove that service-dependent single-record routes are present but conditionally available.",
  "tests": [
    {
      "id": "guides-get-one-availability",
      "method": "GET",
      "path": "/api/guides/{guideId}",
      "status_classification": "implemented-conditional-verified",
      "accepted_statuses": [
        200,
        404,
        503
      ],
      "available_fixture": "examples/conformance/route-available.response.json",
      "unavailable_fixture": "examples/conformance/route-conditionally-unavailable.response.json",
      "repo_assertions": [
        "infra/cloudflare/src/core/router.js exposes the guides single-record route",
        "infra/cloudflare/src/service/index.js binds readGuide",
        "infra/cloudflare/src/service/guides.js defines readGuide"
      ]
    },
    {
      "id": "sessions-get-one-availability",
      "method": "GET",
      "path": "/api/sessions/{sessionId}",
      "status_classification": "implemented-conditional-verified",
      "accepted_statuses": [
        200,
        404,
        503
      ],
      "available_fixture": "examples/conformance/route-available.response.json",
      "unavailable_fixture": "examples/conformance/route-conditionally-unavailable.response.json",
      "repo_assertions": [
        "infra/cloudflare/src/core/router.js exposes the sessions single-record route",
        "infra/cloudflare/src/service/index.js binds getSession",
        "infra/cloudflare/src/service/sessions.js defines getSession"
      ]
    },
    {
      "id": "journal-get-one-availability",
      "method": "GET",
      "path": "/api/journal-entries/{entryId}",
      "status_classification": "implemented-conditional-verified",
      "accepted_statuses": [
        200,
        404,
        503
      ],
      "available_fixture": "examples/conformance/route-available.response.json",
      "unavailable_fixture": "examples/conformance/route-conditionally-unavailable.response.json",
      "repo_assertions": [
        "infra/cloudflare/src/core/router.js exposes the journal single-record route",
        "infra/cloudflare/src/service/index.js binds getJournalEntry",
        "infra/cloudflare/src/service/journals.js defines getJournalEntry"
      ]
    }
  ]
}
