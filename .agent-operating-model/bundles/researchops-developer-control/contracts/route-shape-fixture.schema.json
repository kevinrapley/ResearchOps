{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchops.local/schemas/route-shape-fixture.schema.json",
  "title": "ResearchOps route shape fixture",
  "type": "object",
  "required": ["route", "method", "status", "shape"],
  "properties": {
    "route": {"type": "string"},
    "method": {"type": "string"},
    "status": {"type": "integer"},
    "context": {"type": "string"},
    "shape": {"type": "object"},
    "requiredFields": {"type": "array", "items": {"type": "string"}},
    "optionalFields": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "string"}
  }
}
