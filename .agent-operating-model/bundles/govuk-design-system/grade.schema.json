{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grader Output Schema",
  "type": "object",
  "properties": {
    "grader_id": {
      "type": "string"
    },
    "label": {
      "type": "string",
      "enum": ["pass", "fail_revise"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "criteria_passed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "criteria_failed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hard_fail_triggered": {
      "type": "boolean"
    },
    "revision_required": {
      "type": "boolean"
    },
    "escalation_required": {
      "type": "boolean"
    },
    "explanation": {
      "type": "string"
    }
  },
  "required": [
    "grader_id",
    "label",
    "confidence",
    "hard_fail_triggered",
    "revision_required",
    "escalation_required",
    "explanation"
  ]
}