<?xml version="1.0" encoding="utf-8"?>
<grader_module id="component-guidance-grader" version="3.0">
  <purpose>Validate answers that provide guidance for GOV.UK components.</purpose>
  <inputs>
    <input>user_request</input>
    <input>response_draft</input>
  </inputs>
  <labels>
    <label>pass</label>
    <label>fail_revise</label>
  </labels>
  <output_contract_ref>grade.schema.json</output_contract_ref>
  <hard_fail_conditions>
    <condition rule_id="MISSING-CITATION">The response must include at least one citation formatted with the tether ID syntax.</condition>
  </hard_fail_conditions>
  <criteria>
    <criterion id="COMPONENT-CITATION" severity="block" enforcement_type="self" observability="deterministic">
      <intent>Ensure that component guidance answers include a citation.</intent>
      <trigger_context>
        <condition key="user_request.matches_regex">(?i)component\s</condition>
      </trigger_context>
      <expected_state>
        <condition key="response_draft.contains_tether_id">True</condition>
      </expected_state>
      <on_fail>
        <type>fail</type>
        <message>Your component guidance answer must include a citation from the GOV.UK Design System.</message>
      </on_fail>
    </criterion>
    <criterion id="COMPONENT-WHEN-TO-USE" severity="warn" enforcement_type="self" observability="deterministic">
      <intent>Encourage answers to describe when a component should be used.</intent>
      <trigger_context>
        <condition key="user_request.matches_regex">(?i)component\s</condition>
      </trigger_context>
      <expected_state>
        <condition key="response_draft.contains_regex">(?i)when\s+to\s+use</condition>
      </expected_state>
      <on_fail>
        <type>fail</type>
        <message>Please explain when the component should be used.</message>
      </on_fail>
    </criterion>
  </criteria>
</grader_module>