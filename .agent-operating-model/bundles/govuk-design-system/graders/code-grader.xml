<?xml version="1.0" encoding="utf-8"?>
<grader_module id="code-grader" version="3.0">
  <purpose>Check generated code snippets for GOV.UK components and patterns.</purpose>
  <inputs>
    <input>user_request</input>
    <input>response_draft</input>
  </inputs>
  <labels>
    <label>pass</label>
    <label>fail_revise</label>
  </labels>
  <output_contract_ref>grade.schema.json</output_contract_ref>
  <hard_fail_conditions>
    <condition rule_id="MISSING-CITATION">The response must include at least one citation formatted with the tether ID syntax.</condition>
  </hard_fail_conditions>
  <criteria>
    <criterion id="CODE-CITATION" severity="block" enforcement_type="self" observability="deterministic">
      <intent>Ensure that code generation answers include a citation.</intent>
      <trigger_context>
        <condition key="user_request.matches_regex">(?i)build|code|implementation</condition>
      </trigger_context>
      <expected_state>
        <condition key="response_draft.contains_tether_id">True</condition>
      </expected_state>
      <on_fail>
        <type>fail</type>
        <message>Your code answer must include at least one citation.</message>
      </on_fail>
    </criterion>
    <criterion id="CODE-GOVUK-CLASS" severity="warn" enforcement_type="self" observability="deterministic">
      <intent>Encourage generated code to use GOV.UK CSS classes.</intent>
      <trigger_context>
        <condition key="user_request.matches_regex">(?i)build|code|implementation</condition>
      </trigger_context>
      <expected_state>
        <condition key="response_draft.contains_regex">govuk-</condition>
      </expected_state>
      <on_fail>
        <type>fail</type>
        <message>Generated code should use GOV.UK classes (such as govuk-button, govuk-input). Please revise your code.</message>
      </on_fail>
    </criterion>
    <criterion id="CODE-CONTAINS-TAGS" severity="warn" enforcement_type="self" observability="deterministic">
      <intent>Encourage inclusion of markup in code answers.</intent>
      <trigger_context>
        <condition key="user_request.matches_regex">(?i)build|code|implementation</condition>
      </trigger_context>
      <expected_state>
        <condition key="response_draft.contains_regex"><</condition>
      </expected_state>
      <on_fail>
        <type>fail</type>
        <message>When asked to build or implement, include markup in your answer (for example, HTML or Nunjucks).</message>
      </on_fail>
    </criterion>
  </criteria>
</grader_module>