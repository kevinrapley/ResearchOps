{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prompt Bundle Variables Schema",
  "type": "object",
  "properties": {
    "user_request": {
      "type": "string"
    },
    "active_mode": {
      "type": "string"
    },
    "active_role": {
      "type": "string"
    },
    "active_phase": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "pre-discovery",
        "discovery",
        "alpha",
        "beta",
        "live",
        null
      ]
    },
    "requested_template": {
      "type": [
        "string",
        "null"
      ]
    },
    "focus_primitive": {
      "type": [
        "string",
        "null"
      ]
    },
    "depth": {
      "type": "string",
      "enum": [
        "shallow",
        "standard",
        "deep"
      ]
    },
    "conversation_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "knowledge_snippets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "high_stakes": {
      "type": "boolean"
    },
    "debate_mode": {
      "type": "boolean"
    },
    "available_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "user_request",
    "active_mode",
    "depth",
    "high_stakes",
    "debate_mode"
  ]
}