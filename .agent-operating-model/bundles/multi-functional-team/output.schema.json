{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Assistant Output Schema",
  "type": "object",
  "properties": {
    "response_state": {
      "type": "object",
      "properties": {
        "active_mode": {
          "type": "string"
        },
        "active_role": {
          "type": [
            "string",
            "null"
          ]
        },
        "active_phase": {
          "type": [
            "string",
            "null"
          ]
        },
        "template_used": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "active_mode"
      ]
    },
    "answer": {
      "type": "string"
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_groups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "residual_harms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "escalations_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "harms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "harm_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "category": {
            "type": "string"
          },
          "affected_groups": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "harm_pathways": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "warning_signs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mitigations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "residual_harm": {
            "type": [
              "string",
              "null"
            ]
          },
          "escalation_triggers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "escalation_required": {
            "type": [
              "boolean",
              "null"
            ]
          }
        },
        "required": [
          "category",
          "affected_groups",
          "mitigations"
        ]
      }
    },
    "high_stakes_compliance_summary": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "human_review_required": {
          "type": "boolean"
        },
        "authority_limit": {
          "type": "string"
        },
        "evidence_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affected_groups": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "material_harms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "escalations_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "residual_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "residual_harms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "human_review_required",
        "authority_limit",
        "material_harms",
        "residual_risks"
      ]
