<?xml version="1.0" encoding="utf-8"?>
<template_module id="m365-agent-deployment-checklist" version="1.0.0">
  <title>Microsoft 365 Agent Deployment Checklist</title>
  <template_block name="microsoft-365-agent-deployment-checklist" title="Microsoft 365 Agent Deployment Checklist">
    <statement>Use before deploying or materially changing a Microsoft 365 agent, Copilot workflow, or connected automation.</statement>
  </template_block>
  <template_block name="ownership" title="Ownership">
    <checklist ordered="false">
      <entry level="0">Named service owner</entry>
      <entry level="0">Named operational owner</entry>
      <entry level="0">Named support route</entry>
      <entry level="0">Named security / privacy contacts where required</entry>
    </checklist>
  </template_block>
  <template_block name="purpose-and-scope" title="Purpose and scope">
    <checklist ordered="false">
      <entry level="0">Clear business purpose</entry>
      <entry level="0">User groups in scope</entry>
      <entry level="0">Actions the agent may take</entry>
      <entry level="0">Actions the agent must not take</entry>
    </checklist>
  </template_block>
  <template_block name="data-and-classification" title="Data and classification">
    <checklist ordered="false">
      <entry level="0">Data sources listed</entry>
      <entry level="0">Storage locations listed</entry>
      <entry level="0">Personal data identified</entry>
      <entry level="0">Sensitivity labels / handling classes identified</entry>
      <entry level="0">External sharing implications checked</entry>
    </checklist>
  </template_block>
  <template_block name="identity-access-and-connectors" title="Identity, access, and connectors">
    <checklist ordered="false">
      <entry level="0">Entra groups / app identities defined</entry>
      <entry level="0">Least-privilege access confirmed</entry>
      <entry level="0">Connector inventory completed</entry>
      <entry level="0">Connector approvals confirmed</entry>
      <entry level="0">Secrets handling route defined</entry>
    </checklist>
  </template_block>
  <template_block name="security-and-privacy-controls" title="Security and privacy controls">
    <checklist ordered="false">
      <entry level="0">Logging and audit route defined</entry>
      <entry level="0">DLP / retention / records implications checked</entry>
      <entry level="0">DPIA screening completed where relevant</entry>
      <entry level="0">Human review points defined</entry>
      <entry level="0">High-risk actions gated</entry>
    </checklist>
  </template_block>
  <template_block name="quality-and-operability" title="Quality and operability">
    <checklist ordered="false">
      <entry level="0">Test scope completed</entry>
      <entry level="0">Accessibility implications reviewed</entry>
      <entry level="0">Monitoring and incident route defined</entry>
      <entry level="0">Rollback / disable route defined</entry>
      <entry level="0">Support documentation ready</entry>
    </checklist>
  </template_block>
  <template_block name="governance-and-transparency" title="Governance and transparency">
    <checklist ordered="false">
      <entry level="0">Policy / legal review points identified</entry>
      <entry level="0">ATRS screening considered where relevant</entry>
      <entry level="0">Equality impact screening considered</entry>
      <entry level="0">Human review register completed</entry>
      <entry level="0">Residual risks accepted by accountable human</entry>
    </checklist>
  </template_block>
  <template_block name="recommendation" title="Recommendation">
    <checklist ordered="false">
      <entry level="0">Not ready</entry>
      <entry level="0">Ready with conditions</entry>
      <entry level="0">Ready for accountable human sign-off</entry>
    </checklist>
  </template_block>
</template_module>
