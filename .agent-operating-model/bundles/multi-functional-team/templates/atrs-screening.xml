<?xml version="1.0" encoding="utf-8"?>
<template_module id="atrs-screening" version="1.0.0">
  <title>ATRS Screening Template</title>
  <template_block name="atrs-screening-template" title="ATRS Screening Template">
    <statement>Use when a Microsoft 365 agent, automation, scoring approach, or decision-support workflow may need an Algorithmic Transparency Recording Standard style review.</statement>
  </template_block>
  <template_block name="service-and-use-case" title="Service and use case">
    <checklist ordered="false">
      <entry level="0">Service / team</entry>
      <entry level="0">Named owner</entry>
      <entry level="0">M365 surface in scope</entry>
      <entry level="0">Problem being addressed</entry>
    </checklist>
  </template_block>
  <template_block name="decision-or-recommendation-in-scope" title="Decision or recommendation in scope">
    <checklist ordered="false">
      <entry level="0">What the agent or logic does</entry>
      <entry level="0">Whether it supports, recommends, ranks, flags, or decides</entry>
      <entry level="0">Who is affected</entry>
    </checklist>
  </template_block>
  <template_block name="data-and-evidence" title="Data and evidence">
    <checklist ordered="false">
      <entry level="0">Data sources</entry>
      <entry level="0">Personal data involved</entry>
      <entry level="0">Sensitive classes or labels</entry>
      <entry level="0">Data quality limitations</entry>
    </checklist>
  </template_block>
  <template_block name="logic-or-model-description" title="Logic or model description">
    <checklist ordered="false">
      <entry level="0">Rules, prompts, model, classifier, or workflow</entry>
      <entry level="0">Human-configured thresholds or criteria</entry>
      <entry level="0">Uncertainty or known failure modes</entry>
    </checklist>
  </template_block>
  <template_block name="human-oversight" title="Human oversight">
    <checklist ordered="false">
      <entry level="0">Human review points</entry>
      <entry level="0">Who can override the output</entry>
      <entry level="0">What must never be automated</entry>
    </checklist>
  </template_block>
  <template_block name="risk-and-impact" title="Risk and impact">
    <checklist ordered="false">
      <entry level="0">Individual impact</entry>
      <entry level="0">Group or equality impact</entry>
      <entry level="0">Legal / policy / privacy / security concerns</entry>
      <entry level="0">Residual risks</entry>
    </checklist>
  </template_block>
  <template_block name="transparency-and-accountability" title="Transparency and accountability">
    <checklist ordered="false">
      <entry level="0">What can be explained to users or staff</entry>
      <entry level="0">What will be recorded</entry>
      <entry level="0">Escalation route</entry>
      <entry level="0">Recommendation: screen out / record / escalate for fuller ATRS work</entry>
    </checklist>
  </template_block>
</template_module>
