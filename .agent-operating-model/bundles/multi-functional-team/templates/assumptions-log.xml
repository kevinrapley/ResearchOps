<?xml version="1.0" encoding="utf-8"?>
<template_module id="assumptions-log" version="1.0.0">
  <title>Assumptions Log</title>
  <purpose>
    <statement>Maintain a living log of assumptions that underpin thinking, decisions, or plans, without treating those assumptions as facts.</statement>
    <statement>This log exists to make uncertainty explicit.</statement>
  </purpose>
  <template_block name="assumptions-log" title="Assumptions Log">
    <mapping_table>
      <columns>
        <column>ID</column>
        <column>Assumption</column>
        <column>Why it matters</column>
        <column>Current status</column>
        <column>Evidence (if any)</column>
        <column>Risk if wrong</column>
      </columns>
      <rows>
        <row>
          <cell column="ID">A‑01</cell>
          <cell column="Assumption"/>
          <cell column="Why it matters"/>
          <cell column="Current status"/>
          <cell column="Evidence (if any)"/>
          <cell column="Risk if wrong"/>
        </row>
      </rows>
    </mapping_table>
  </template_block>
  <template_block name="status-definitions" title="Status definitions">
    <checklist ordered="false">
      <entry level="0">Unvalidated – no evidence yet</entry>
      <entry level="0">Partially explored – some signals, still uncertain</entry>
      <entry level="0">Challenged – evidence contradicts assumption</entry>
      <entry level="0">Retired – no longer relevant</entry>
    </checklist>
  </template_block>
  <template_block name="cross-cutting-themes" title="Cross‑cutting themes">
    <statement>Note any patterns across assumptions:</statement>
    <checklist ordered="false" purpose="note-any-patterns-across-assumptions">
      <entry level="0">repeated uncertainty</entry>
      <entry level="0">common dependencies</entry>
      <entry level="0">systemic risks</entry>
    </checklist>
  </template_block>
  <prompt_set>
    <statement>List questions that would materially reduce uncertainty if answered.</statement>
  </prompt_set>
  <template_block name="linting-rules-machine-readable-yaml" title="Linting Rules (Machine‑Readable YAML)">
    <statement>```yaml lint: mode: hard-fail</statement>
    <statement>assumptions_integrity: description: &gt; Assumptions must remain assumptions unless explicitly validated. rule: Reject outputs that present assumptions as facts.</statement>
    <statement>no_validation_language: disallowed_terms:</statement>
    <checklist ordered="false" purpose="no-validation-language-disallowed-terms">
      <entry level="3">proven</entry>
      <entry level="3">confirmed</entry>
      <entry level="3">clearly true</entry>
      <entry level="3">we know that</entry>
    </checklist>
    <statement>severity: error</statement>
    <statement>risk_if_wrong_required: description: Every assumption must include a risk-if-wrong entry. severity: error</statement>
    <statement>evidence_not_required_but_controlled: description: Evidence may be absent, but must not be invented. severity: error</statement>
    <statement>no_decision_language: disallowed_terms:</statement>
    <checklist ordered="false" purpose="no-decision-language-disallowed-terms">
      <entry level="3">therefore we will</entry>
      <entry level="3">this means we should</entry>
    </checklist>
    <statement>severity: error</statement>
    <statement>tone: allowed:</statement>
    <checklist ordered="false" purpose="tone-allowed">
      <entry level="3">neutral</entry>
      <entry level="3">explicit about uncertainty</entry>
    </checklist>
    <statement>disallowed:</statement>
    <checklist ordered="false" purpose="disallowed">
      <entry level="3">confident</entry>
      <entry level="3">persuasive</entry>
    </checklist>
    <statement>severity: error ```</statement>
    <statement>If any lint rule is violated, the assistant must rewrite its output before responding.</statement>
  </template_block>
</template_module>
