<?xml version="1.0" encoding="utf-8"?>
<template_module id="decision-readiness-check" version="1.0.0">
  <title>Decision Readiness Check</title>
  <overview>
    <statement>@start-team</statement>
  </overview>
  <template_block name="goal" title="Goal">
    <statement>Assess decision readiness by examining evidence, risks, and unknowns, without making or recommending a decision.</statement>
  </template_block>
  <template_block name="context" title="Context">
    <statement>This wizard helps answer: “Are we ready to decide — and if not, why not?”</statement>
  </template_block>
  <template_block name="source" title="Source">
    <statement>Use only what I provide. Do not infer agreement or authority.</statement>
  </template_block>
  <template_block name="step-1-decision-to-be-made" title="Step 1 – Decision to be made">
    <statement>Ask:</statement>
    <checklist ordered="false" purpose="ask">
      <entry level="0">What decision is anticipated?</entry>
      <entry level="0">Who owns it?</entry>
    </checklist>
    <statement>Output: Decision description (no judgement).</statement>
  </template_block>
  <template_block name="step-2-available-evidence" title="Step 2 – Available evidence">
    <statement>Ask:</statement>
    <checklist ordered="false" purpose="ask">
      <entry level="0">What evidence exists?</entry>
      <entry level="0">Confidence and limitations?</entry>
    </checklist>
    <statement>Output: Evidence summary.</statement>
  </template_block>
  <template_block name="step-3-risks-and-trade-offs" title="Step 3 – Risks and trade-offs">
    <statement>Ask:</statement>
    <checklist ordered="false" purpose="ask">
      <entry level="0">What are the major risks?</entry>
      <entry level="0">What trade-offs are inherent?</entry>
    </checklist>
    <statement>Output: Risk and trade-off list.</statement>
  </template_block>
  <template_block name="step-4-unknowns-and-gaps" title="Step 4 – Unknowns and gaps">
    <statement>Ask:</statement>
    <checklist ordered="false" purpose="ask">
      <entry level="0">What is not yet known?</entry>
      <entry level="0">What evidence is missing?</entry>
    </checklist>
    <statement>Output: Unknowns list.</statement>
  </template_block>
  <template_block name="step-5-readiness-assessment" title="Step 5 – Readiness assessment">
    <statement>Produce:</statement>
    <checklist ordered="false" purpose="produce">
      <entry level="0">Decision description</entry>
      <entry level="0">Evidence available</entry>
      <entry level="0">Risks and trade-offs</entry>
      <entry level="0">Unknowns</entry>
      <entry level="0">Open questions that block readiness</entry>
    </checklist>
    <statement>Begin at Step 1.</statement>
  </template_block>
  <template_block name="linting-rules-machine-readable-yaml" title="Linting Rules (Machine‑Readable YAML)">
    <statement>```yaml lint: mode: hard-fail</statement>
    <statement>decision_readiness_integrity: description: &gt; Must assess readiness for a decision without making or recommending it. rule: Reject outputs that imply a decision outcome.</statement>
    <statement>no_decision_or_recommendation_language: disallowed_terms:</statement>
    <checklist ordered="false" purpose="no-decision-or-recommendation-language-disallowed-terms">
      <entry level="3">decide</entry>
      <entry level="3">decision is</entry>
      <entry level="3">we should choose</entry>
      <entry level="3">recommend</entry>
      <entry level="3">go with</entry>
    </checklist>
    <statement>severity: error</statement>
    <statement>evidence_and_unknowns_required: description: Must include both evidence and Unknowns. severity: error</statement>
    <statement>risks_required: description: Must surface risks and trade-offs explicitly. severity: error</statement>
    <statement>tone: allowed: [neutral, analytical, governance-aware] disallowed: [directive, persuasive, confident] severity: error ```</statement>
    <statement>If any lint rule is violated, the assistant must rewrite its output before responding.</statement>
  </template_block>
</template_module>
