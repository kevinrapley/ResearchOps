<?xml version="1.0" encoding="utf-8"?>
<template_module id="evidence-pack-index" version="1.0.0">
  <title>Evidence Pack Index</title>
  <purpose>
    <statement>Provide a traceable index of evidence artefacts relevant to a service or decision, without interpreting, summarising, or drawing conclusions.</statement>
  </purpose>
  <template_block name="evidence-index" title="Evidence Index">
    <mapping_table>
      <columns>
        <column>ID</column>
        <column>Evidence name</column>
        <column>Type</column>
        <column>Source</column>
        <column>Date</column>
        <column>Confidence</column>
        <column>Notes</column>
      </columns>
      <rows>
        <row>
          <cell column="ID">E‑01</cell>
          <cell column="Evidence name"/>
          <cell column="Type"/>
          <cell column="Source"/>
          <cell column="Date"/>
          <cell column="Confidence"/>
          <cell column="Notes"/>
        </row>
      </rows>
    </mapping_table>
  </template_block>
  <template_block name="evidence-types" title="Evidence types">
    <checklist ordered="false">
      <entry level="0">Research</entry>
      <entry level="0">Analytics</entry>
      <entry level="0">Audit</entry>
      <entry level="0">Policy</entry>
      <entry level="0">Operational data</entry>
      <entry level="0">External report</entry>
    </checklist>
  </template_block>
  <template_block name="confidence-scale" title="Confidence scale">
    <checklist ordered="false">
      <entry level="0">Low / Medium / High (based on freshness, coverage, and reliability)</entry>
    </checklist>
  </template_block>
  <template_block name="coverage-gaps" title="Coverage gaps">
    <statement>List:</statement>
    <checklist ordered="false" purpose="list">
      <entry level="0">areas with no evidence</entry>
      <entry level="0">outdated evidence</entry>
      <entry level="0">evidence with known limitations</entry>
    </checklist>
  </template_block>
  <template_block name="dependencies" title="Dependencies">
    <statement>List dependencies required to access, interpret, or rely on the evidence.</statement>
  </template_block>
  <template_block name="linting-rules-machine-readable-yaml" title="Linting Rules (Machine‑Readable YAML)">
    <statement>```yaml lint: mode: hard-fail</statement>
    <statement>evidence_index_integrity: description: &gt; Evidence indices must catalogue evidence, not analyse or interpret it. rule: Reject outputs that include conclusions or recommendations.</statement>
    <statement>no_interpretation_language: disallowed_terms:</statement>
    <checklist ordered="false" purpose="no-interpretation-language-disallowed-terms">
      <entry level="3">therefore</entry>
      <entry level="3">this shows</entry>
      <entry level="3">indicates that</entry>
      <entry level="3">suggests</entry>
    </checklist>
    <statement>severity: error</statement>
    <statement>confidence_enum_enforced: allowed_values:</statement>
    <checklist ordered="false" purpose="confidence-enum-enforced-allowed-values">
      <entry level="3">Low</entry>
      <entry level="3">Medium</entry>
      <entry level="3">High</entry>
    </checklist>
    <statement>severity: error</statement>
    <statement>gaps_required: description: Evidence gaps must be explicitly listed. severity: error</statement>
    <statement>no_decision_language: disallowed_terms:</statement>
    <checklist ordered="false" purpose="no-decision-language-disallowed-terms">
      <entry level="3">based on this evidence</entry>
      <entry level="3">we should decide</entry>
    </checklist>
    <statement>severity: error</statement>
    <statement>tone: allowed:</statement>
    <checklist ordered="false" purpose="tone-allowed">
      <entry level="3">neutral</entry>
      <entry level="3">cataloguing</entry>
      <entry level="3">factual</entry>
    </checklist>
    <statement>disallowed:</statement>
    <checklist ordered="false" purpose="disallowed">
      <entry level="3">analytical</entry>
      <entry level="3">persuasive</entry>
    </checklist>
    <statement>severity: error ```</statement>
    <statement>If any lint rule is violated, the assistant must rewrite its output before responding.</statement>
  </template_block>
</template_module>
