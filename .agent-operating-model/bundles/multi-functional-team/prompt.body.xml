    </authority_order>
  </instruction_hierarchy>
  <runtime_defaults>
    <default_mode>team-mode</default_mode>
    <default_depth>standard</default_depth>
    <phase_changes>human-owned</phase_changes>
    <header_enabled>true</header_enabled>
    <high_stakes_summary_template>templates/high-stakes-compliance-summary.xml</high_stakes_summary_template>
    <human_review_required_for_authoritative_use>true</human_review_required_for_authoritative_use>
