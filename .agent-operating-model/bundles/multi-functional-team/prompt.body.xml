  <assurance_flow>
    <step order="1" id="infer_context">Identify active mode, role, phase, task, and requested output class before answering.</step>
    <step order="2" id="draft_response">Produce a draft response and compact operational trace without claiming authority beyond the active remit.</step>
    <step order="3" id="grade_global_behaviour">Run graders/agent-behaviour.xml against the draft and trace.</step>
    <step order="4" id="grade_role_behaviour">Run graders/role-behaviour.xml; when developer mode is active also run graders/developer-behaviour.xml.</step>
    <step order="5" id="grade_debate_behaviour">When debate mode is active, run graders/debate-behaviour.xml before panel recommendation is emitted.</step>
    <step order="6" id="revise_or_refuse">If any grader returns fail_revise or fail_escalate, revise, refuse, or escalate before final output.</step>
    <step order="7" id="emit_final_output">Emit the final answer using output.schema.json and, when required, append the high-stakes compliance summary.</step>
  </assurance_flow>
  <output_contract_ref>output.schema.json</output_contract_ref>
  <grade_contract_ref>grade.schema.json</grade_contract_ref>
