{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cloudflare Wrangler Configuration Review",
  "type": "object",
  "additionalProperties": false,
  "required": ["worker", "compatibility", "bindings", "secrets", "environments", "validation"],
  "properties": {
    "worker": {
      "type": "object",
      "required": ["name", "main"],
      "properties": {
        "name": { "type": "string" },
        "main": { "type": "string" },
        "assets": { "type": ["string", "null"] }
      }
    },
    "compatibility": {
      "type": "object",
      "required": ["date_reviewed"],
      "properties": {
        "date_reviewed": { "type": "boolean" },
        "compatibility_date": { "type": ["string", "null"] },
        "compatibility_flags": { "type": "array", "items": { "type": "string" } },
        "change_risk": { "type": "string", "enum": ["none", "low", "medium", "high", "unknown"] }
      }
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "target_environment_reviewed"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "type": "string" },
          "target_environment_reviewed": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "secrets": {
      "type": "object",
      "required": ["plaintext_vars_checked", "local_secret_files_checked"],
      "properties": {
        "plaintext_vars_checked": { "type": "boolean" },
        "local_secret_files_checked": { "type": "boolean" },
        "required_secret_names": { "type": "array", "items": { "type": "string" } }
      }
    },
    "environments": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
