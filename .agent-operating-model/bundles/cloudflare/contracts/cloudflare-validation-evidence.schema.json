{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cloudflare Validation Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope", "environment", "evidence_type", "result", "limitations"],
  "properties": {
    "scope": { "type": "string" },
    "environment": { "type": "string", "enum": ["local", "preview", "production", "unknown"] },
    "evidence_type": { "type": "string", "enum": ["unit-test", "integration-test", "wrangler-output", "deployment-output", "log-review", "manual-smoke-test", "not-run"] },
    "result": { "type": "string", "enum": ["pass", "fail", "not-run", "unknown"] },
    "cloudflare_products": { "type": "array", "items": { "type": "string" } },
    "bindings_exercised": { "type": "array", "items": { "type": "string" } },
    "deployment_reference": { "type": ["string", "null"] },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
