<template_module id="wrangler-config-review" version="1.0.0">
  <title>Wrangler Configuration Review</title>
  <template_block name="review" title="Review">
    <checklist ordered="false">
      <entry level="0">Entrypoint and compatibility date.</entry>
      <entry level="0">Assets directory, if used.</entry>
