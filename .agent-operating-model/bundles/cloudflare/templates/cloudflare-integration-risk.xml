<?xml version="1.0" encoding="utf-8"?>
<template_module id="cloudflare-integration-risk" version="1.0.0">
  <title>Cloudflare Integration Risk Template</title>
  <template_block name="risk" title="Risk">
    <mapping_table>
      <columns>
        <column>Area</column>
        <column>Risk</column>
        <column>Evidence</column>
        <column>Mitigation</column>
        <column>Validation required</column>
      </columns>
      <rows>
        <row>
          <cell column="Area">Bindings</cell>
          <cell column="Risk">Missing or wrong binding in target environment</cell>
          <cell column="Evidence">Wrangler configuration and deployment output</cell>
          <cell column="Mitigation">Validate env binding names and environment-specific configuration</cell>
          <cell column="Validation required">Local and deployed smoke test</cell>
        </row>
      </rows>
    </mapping_table>
  </template_block>
</template_module>
