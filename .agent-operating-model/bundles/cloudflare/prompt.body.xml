<?xml version="1.0" encoding="utf-8"?>
<prompt_bundle id="cloudflare" version="1.0.0" default_mode="cloudflare-build" xml_profile="native-semantic-xml/v1">
  <bundle_identity>
    <name>Cloudflare Developer Platform Prompt Bundle</name>
    <description>Canonical Cloudflare bundle for Workers, Pages, Wrangler, bindings, storage, queues, workflows, AI and deployment work, sourced only from developers.cloudflare.com.</description>
    <status>canonical</status>
  </bundle_identity>
  <runtime_defaults>
    <default_mode>cloudflare-build</default_mode>
    <source_of_truth>https://developers.cloudflare.com/</source_of_truth>
    <do_not_invent_cloudflare_behaviour>true</do_not_invent_cloudflare_behaviour>
    <prefer_bindings_inside_workers>true</prefer_bindings_inside_workers>
    <require_secret_separation>true</require_secret_separation>
  </runtime_defaults>
  <assembly>
    <always_load>references/source-catalog.yaml</always_load>
    <always_load>references/cloudflare-platform-context.xml</always_load>
    <always_load>references/workers-runtime.xml</always_load>
    <always_load>references/wrangler-configuration.xml</always_load>
    <always_load>references/bindings-and-secrets.xml</always_load>
    <always_load>references/storage-and-state.xml</always_load>
    <always_load>references/pages-and-deployment.xml</always_load>
    <always_load>references/queues-workflows-ai.xml</always_load>
  </assembly>
  <role_registry>
    <role_ref id="cloudflare-developer" file="roles/cloudflare-developer.xml"/>
    <role_ref id="cloudflare-devops" file="roles/cloudflare-devops.xml"/>
    <role_ref id="cloudflare-security" file="roles/cloudflare-security.xml"/>
  </role_registry>
  <template_registry>
    <template_ref id="worker-route" file="templates/worker-route.xml"/>
    <template_ref id="wrangler-config-review" file="templates/wrangler-config-review.xml"/>
    <template_ref id="cloudflare-integration-risk" file="templates/cloudflare-integration-risk.xml"/>
  </template_registry>
  <grader_registry>
    <grader_ref id="cloudflare-behaviour" file="graders/cloudflare-behaviour.xml"/>
  </grader_registry>
  <contracts>
    <inputs ref="variables.schema.json"/>
    <outputs ref="output.schema.json"/>
    <grading ref="grade.schema.json"/>
  </contracts>
</prompt_bundle>
