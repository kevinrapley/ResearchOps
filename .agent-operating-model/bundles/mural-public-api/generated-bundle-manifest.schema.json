{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/generated-bundle-manifest.schema.json",
  "title": "Generated Prompt Bundle Manifest",
  "description": "Validates the manifest emitted by a generated prompt bundle. The manifest records what the meta-bundle created, which topology it selected, which contracts and tests are present, and why the bundle is considered complete and publishable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "bundle_id",
    "bundle_version",
    "generated_by_bundle_id",
    "generated_by_bundle_version",
    "target_bundle_class",
    "status",
    "topology",
    "assets",
    "contracts",
    "tests",
    "graders",
    "quality_gates"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version of this manifest schema contract."
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Kebab-case identifier of the generated bundle."
    },
    "bundle_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the generated bundle."
    },
    "generated_by_bundle_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Identifier of the meta-bundle that produced this bundle."
    },
    "generated_by_bundle_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version of the meta-bundle that produced this bundle."
    },
    "target_bundle_class": {
      "type": "string",
      "description": "Class assigned to the generated bundle by the topology policy."
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "release-candidate",
        "published"
      ],
      "description": "Lifecycle status of the generated bundle."
    },
    "topology": {
      "type": "object",
      "description": "Resolved topology for the generated bundle.",
      "additionalProperties": false,
      "required": [
        "schema_ref",
        "folders",
        "non_universal_folder_justifications"
      ],
      "properties": {
        "schema_ref": {
          "type": "string",
          "const": "topology.schema.json",
          "description": "Reference to the schema used to validate the topology object."
        },
        "folders": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "non_universal_folder_justifications": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "folder",
              "reason"
            ],
            "properties": {
              "folder": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "reason": {
                "type": "string",
                "minLength": 10
              }
            }
          },
          "description": "Justification records for non-universal folders created by the bundle."
        }
      }
    },
    "assets": {
      "type": "array",
      "description": "All materialized files and folders in the generated bundle.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "kind",
          "canonical",
          "purpose"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "xml-module",
              "schema",
              "manifest",
              "document",
              "compatibility-export",
              "folder",
              "dataset"
            ]
          },
          "canonical": {
            "type": "boolean"
          },
          "purpose": {
            "type": "string",
            "minLength": 5
          },
          "module_family": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "Optional logical family such as roles, workflows, references, or graders."
          },
          "hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$",
            "description": "Optional SHA-256 digest for immutable publication."
          }
        }
      },
      "minItems": 1
    },
    "contracts": {
      "type": "object",
      "description": "Contract files that define inputs, outputs, grades, and topology if present.",
      "additionalProperties": false,
      "required": [
        "variables",
        "output",
        "grade"
      ],
      "properties": {
        "variables": {
          "type": "string",
          "pattern": "(^|.*/)variables\\.schema\\.json$"
        },
        "output": {
          "type": "string",
          "pattern": "(^|.*/)output\\.schema\\.json$"
        },
        "grade": {
          "type": "string",
          "pattern": "(^|.*/)grade\\.schema\\.json$"
        },
        "topology": {
          "type": "string",
          "pattern": "(^|.*/)topology\\.schema\\.json$"
        },
        "generated_bundle_manifest": {
          "type": "string",
          "pattern": "(^|.*/)generated-bundle-manifest\\.schema\\.json$"
        }
      }
    },
    "tests": {
      "type": "object",
      "description": "Test suite files present in the bundle.",
      "additionalProperties": false,
      "required": [
        "regression",
        "redteam"
      ],
      "properties": {
        "regression": {
          "type": "string",
          "pattern": "(^|.*/)tests\\.regression\\.yaml$"
        },
        "redteam": {
          "type": "string",
          "pattern": "(^|.*/)tests\\.redteam\\.yaml$"
        },
        "evals": {
          "type": "string",
          "pattern": "(^|.*/)evals\\.yaml$"
        }
      }
    },
    "graders": {
      "type": "array",
      "description": "Grader modules or grader assets used to assess the generated bundle.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "grader_id",
          "path",
          "purpose"
        ],
        "properties": {
          "grader_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 5
          },
          "blocks_publish": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "minItems": 1
    },
    "quality_gates": {
      "type": "object",
      "description": "Summary of whether mandatory publication gates passed.",
      "additionalProperties": false,
      "required": [
        "hard_failures",
        "revision_flags",
        "publishable"
      ],
      "properties": {
        "hard_failures": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Hard failures that block release. Use an empty array when none are present."
        },
        "revision_flags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Non-blocking issues that still require revision before publication."
        },
        "publishable": {
          "type": "boolean",
          "description": "True only when no hard failures remain and the bundle passes the required gates."
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "published"
          }
        }
      },
      "then": {
        "properties": {
          "quality_gates": {
            "properties": {
              "publishable": {
                "const": true
              },
              "hard_failures": {
                "maxItems": 0
              }
            }
          }
        }
      }
    }
  ]
}
