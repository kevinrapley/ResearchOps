{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mural Developer Contract Bundle Output",
  "type": "object",
  "required": [
    "summary",
    "request_classification",
    "endpoint_inventory_resolution",
    "recommended_endpoints",
    "endpoint_contracts",
    "request_examples",
    "source_provenance",
    "scope_strategy",
    "architecture",
    "orchestration",
    "implementation_plan",
    "operational_controls",
    "tradeoffs",
    "risks",
    "assumptions",
    "boundary_calls"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "request_classification": {
      "type": "object"
    },
    "endpoint_inventory_resolution": {
      "type": "object"
    },
    "recommended_endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "method",
          "path",
          "why",
          "source_url"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "method": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "why": {
            "type": "string"
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "minimum_scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "source_provenance": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "scope_strategy": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "architecture": {
      "type": "string"
    },
    "orchestration": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operational_controls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tradeoffs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "boundary_calls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "endpoint_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "operation_id",
          "contract_path",
          "method",
          "path",
          "minimum_scopes",
          "path_params",
          "query_params",
          "responses"
        ],
        "properties": {
          "operation_id": {
            "type": "string"
          },
          "contract_path": {
            "type": "string"
          },
          "method": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "minimum_scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "path_params": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "query_params": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "request_body": {
            "type": [
              "object",
              "null"
            ]
          },
          "responses": {
            "type": "object"
          },
          "body_shape_inline": {
            "description": "Fully dereferenced 200 response schema — all $ref links resolved inline. Prefer this over responses.200.body_shape when surfacing response structure to a developer.",
            "type": [
              "object",
              "null"
            ]
          },
          "inline_error_envelope": {
            "description": "Self-contained error schema (code, message, details[]) without a ref hop.",
            "type": "object"
          },
          "contract_strength": {
            "description": "Provenance quality indicators for each contract field.",
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    },
    "request_examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "operation_id",
          "node",
          "ruby",
          "php",
          "python"
        ],
        "properties": {
          "operation_id": {
            "type": "string"
          },
          "node": {
            "type": "string"
          },
          "ruby": {
            "type": "string"
          },
          "php": {
            "type": "string"
          },
          "python": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}