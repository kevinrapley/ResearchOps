{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mural Developer Contract Bundle Grade",
  "type": "object",
  "required": [
    "label",
    "scores",
    "findings"
  ],
  "properties": {
    "label": {
      "type": "string",
      "enum": [
        "pass",
        "pass_with_minor_issues",
        "revise",
        "hard_fail"
      ]
    },
    "scores": {
      "type": "object",
      "properties": {
        "architecture": {
          "type": "number"
        },
        "endpoint_coverage": {
          "type": "number"
        },
        "scope_discipline": {
          "type": "number"
        },
        "operational_hardening": {
          "type": "number"
        },
        "boundary_integrity": {
          "type": "number"
        },
        "source_grounding": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
