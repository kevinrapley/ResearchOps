<template_module id="resource-contract" version="1.0.0">
  <title>MCP Resource Contract Template</title>
  <template_block name="resource-contract" title="Resource contract">
    <checklist ordered="false">
      <entry level="0">Resource URI pattern and owning server.</entry>
      <entry level="0">MIME type, content type and encoding.</entry>
      <entry level="0">Sensitivity, provenance and freshness.</entry>
