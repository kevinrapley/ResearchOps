{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Tooling Validation Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope", "evidence_type", "result", "limitations"],
  "properties": {
    "scope": { "type": "string" },
    "evidence_type": { "type": "string", "enum": ["unit-test", "integration-test", "contract-test", "manual-review", "red-team", "not-run"] },
    "result": { "type": "string", "enum": ["pass", "fail", "not-run", "unknown"] },
    "features": { "type": "array", "items": { "type": "string" } },
    "tools": { "type": "array", "items": { "type": "string" } },
    "resources": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
