{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Agent Tooling Bundle Variables",
  "type": "object",
  "properties": {
    "user_request": { "type": "string" },
    "mcp_features": { "type": "array", "items": { "type": "string" } },
    "tool_side_effects": { "type": "boolean" },
    "resource_sensitivity": { "type": ["string", "null"] },
    "human_consent_required": { "type": "boolean" }
  },
  "required": ["user_request"]
}
