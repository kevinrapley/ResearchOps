{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "resolved_operations",
    "scope_recommendation",
    "implementation_notes"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "resolved_operations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "scope_recommendation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "code_examples": {
      "type": "object",
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}