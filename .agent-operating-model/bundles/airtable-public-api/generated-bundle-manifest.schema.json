{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "bundle_version",
    "entrypoints",
    "inventory_summary"
  ],
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "bundle_version": {
      "type": "string"
    },
    "bundle_kind": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inventory_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "schema_policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "authoritative_schemas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "removed_schema_shims": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "asset_inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "hashes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "bytes"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "bytes": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "anyOf": [
    {
      "required": [
        "asset_inventory"
      ]
    },
    {
      "required": [
        "hashes"
      ]
    }
  ]
}
