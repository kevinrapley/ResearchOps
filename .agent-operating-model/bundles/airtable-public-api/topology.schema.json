{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "bundle_kind",
    "domains",
    "workflows",
    "patterns"
  ],
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "bundle_kind": {
      "type": "string"
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}