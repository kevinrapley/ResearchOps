{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request",
    "preferred_output"
  ],
  "properties": {
    "request": {
      "type": "string"
    },
    "preferred_output": {
      "type": "string",
      "enum": [
        "implementation_plan",
        "endpoint_contracts",
        "code_samples",
        "full_solution"
      ]
    },
    "include_code_examples": {
      "type": "boolean",
      "default": true
    },
    "include_response_shapes": {
      "type": "boolean",
      "default": true
    },
    "target_language": {
      "type": "string",
      "enum": [
        "Node",
        "Ruby",
        "PHP",
        "Python",
        "curl",
        "mixed"
      ]
    },
    "active_mode": {
      "type": "string",
      "enum": [
        "authoring",
        "audit",
        "integration-design",
        "code-generation"
      ]
    }
  }
}