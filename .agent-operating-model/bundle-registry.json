{
	"version": "1.2.0",
	"updated": "2026-05-10",
	"canonicalRoot": ".agent-operating-model/bundles/",
	"defaultLoadOrder": [
		"github-diamond",
		"researchops-developer-control",
		"multi-functional-team"
	],
	"bundles": [
		{
			"id": "github-diamond",
			"name": "GitHub Diamond",
			"role": "primary-repository-governance",
			"precedence": 100,
			"load": "always",
			"canonicalPath": ".agent-operating-model/bundles/github/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": [
				"repository",
				"github",
				"branch",
				"pull request",
				"pr",
				"ci",
				"commit"
			],
			"mustRecordInTrace": true
		},
		{
			"id": "researchops-developer-control",
			"name": "ResearchOps Developer Control",
			"role": "platform-specific-development-control",
			"precedence": 90,
			"load": "always",
			"canonicalPath": ".agent-operating-model/bundles/researchops-developer-control/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": [
				"researchops",
				"platform",
				"worker",
				"service",
				"router",
				"study",
				"project",
				"cloudflare",
				"wrangler",
				"deployment"
			],
			"mustRecordInTrace": true
		},
		{
			"id": "multi-functional-team",
