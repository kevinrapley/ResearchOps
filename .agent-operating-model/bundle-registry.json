{
	"version": "1.4.0",
	"updated": "2026-05-11",
	"canonicalRoot": ".agent-operating-model/bundles/",
	"defaultLoadOrder": [
		"github-diamond",
		"researchops-developer-control",
		"multi-functional-team"
	],
	"bundles": [
		{
			"id": "github-diamond",
			"name": "GitHub Diamond",
			"role": "primary-repository-governance",
			"precedence": 100,
			"load": "always",
			"canonicalPath": ".agent-operating-model/bundles/github/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": ["repository", "github", "branch", "pull request", "pr", "ci", "commit"],
			"mustRecordInTrace": true
		},
		{
			"id": "researchops-developer-control",
			"name": "ResearchOps Developer Control",
			"role": "platform-specific-development-control",
			"precedence": 90,
			"load": "always",
			"canonicalPath": ".agent-operating-model/bundles/researchops-developer-control/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": ["researchops", "platform", "worker", "service", "router", "study", "project", "cloudflare", "wrangler", "deployment"],
			"mustRecordInTrace": true
		},
		{
			"id": "multi-functional-team",
			"name": "Multi-Functional Team",
			"role": "government-product-governance-and-assurance",
			"precedence": 85,
			"load": "always",
			"canonicalPath": ".agent-operating-model/bundles/multi-functional-team/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": ["government", "governance", "assurance", "service standard", "risk", "harm", "ethics", "product"],
			"mustRecordInTrace": true
		},
		{
			"id": "govuk-design-system",
			"name": "GOV.UK Design System",
			"role": "service-ui-accessibility-pattern-control",
			"precedence": 80,
			"load": "conditional",
			"canonicalPath": ".agent-operating-model/bundles/govuk-design-system/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": ["gov.uk", "govuk", "accessibility", "html", "css", "form", "component", "content design", "page"],
			"mustRecordInTrace": true
		},
		{
			"id": "cloudflare",
			"name": "Cloudflare Developer Platform",
			"role": "cloudflare-runtime-deployment-and-bindings-control",
			"precedence": 70,
			"load": "conditional",
			"canonicalPath": ".agent-operating-model/bundles/cloudflare/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": ["cloudflare", "cloudflare deployment", "cloudflare d1", "cloudflare kv", "cloudflare pages", "cloudflare queue", "cloudflare queues", "cloudflare r2", "cloudflare route", "cloudflare routes", "cloudflare worker", "cloudflare workers", "cloudflare workflows", "d1", "durable object", "durable objects", "kv namespace", "r2", "vectorize", "worker fetch", "worker fetch handler", "worker route", "worker runtime", "workers fetch", "workers fetch handler", "workers route", "workers runtime", "workers ai", "wrangler", "wrangler binding", "wrangler bindings", "wrangler deploy", "wrangler deployment"],
			"mustRecordInTrace": true
		},
		{
			"id": "openai-platform",
			"name": "OpenAI Platform",
			"role": "openai-api-model-and-safety-control",
			"precedence": 65,
			"load": "conditional",
			"canonicalPath": ".agent-operating-model/bundles/openai/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": ["openai", "openai api", "openai platform", "responses api", "structured outputs", "function calling", "file search", "vector store", "vector stores", "embeddings", "batch api", "openai webhook", "openai webhooks", "realtime api", "evals api", "openai evals"],
			"mustRecordInTrace": true
		},
		{
			"id": "mcp-agent-tooling",
			"name": "MCP Agent Tooling",
			"role": "mcp-protocol-tool-resource-and-agent-safety-control",
			"precedence": 64,
			"load": "conditional",
			"canonicalPath": ".agent-operating-model/bundles/mcp-agent-tooling/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": ["model context protocol", "mcp", "mcp server", "mcp client", "mcp tool", "mcp tools", "mcp resource", "mcp resources", "mcp prompt", "mcp prompts", "mcp sampling", "mcp roots", "mcp elicitation", "mcp tool consent", "mcp tool invocation", "mcp tool contract", "mcp agent tooling", "mcp agent tool", "mcp agent tools", "agent-tooling safety"],
			"mustRecordInTrace": true
		},
		{
			"id": "airtable-public-api",
			"name": "Airtable Public API",
			"role": "airtable-integration-control",
			"precedence": 60,
			"load": "conditional",
			"canonicalPath": ".agent-operating-model/bundles/airtable-public-api/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": ["airtable", "record", "records", "linked record", "filterbyformula", "attachment", "comment", "base schema", "webhook"],
			"mustRecordInTrace": true
		},
		{
			"id": "mural-public-api",
			"name": "Mural Public API",
			"role": "mural-integration-control",
			"precedence": 60,
			"load": "conditional",
			"canonicalPath": ".agent-operating-model/bundles/mural-public-api/",
			"promptSpec": "prompt.spec.yaml",
			"promptBody": "prompt.body.xml",
			"keywords": ["mural", "oauth", "workspace", "room", "mural board", "widget", "sticky note", "template", "tag"],
			"mustRecordInTrace": true
		}
	]
}
