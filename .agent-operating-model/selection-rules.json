{
	"version": "1.0.0",
	"purpose": "Provide auditable structured rules for selecting agent bundles from typed task signals before falling back to registry keyword evidence.",
	"rules": [
		{
			"id": "always-github-diamond",
			"bundleId": "github-diamond",
			"traceLayer": "operational",
			"type": "always",
			"requiredSignals": ["repository-affecting-task"]
		},
		{
			"id": "always-researchops-developer",
			"bundleId": "researchops-developer",
			"traceLayer": "operational",
			"type": "always",
			"requiredSignals": ["repository-affecting-task"]
		},
		{
			"id": "always-gov-product-assistant",
			"bundleId": "gov-product-assistant-gold-standard",
			"traceLayer": "operational",
			"type": "always",
			"requiredSignals": ["government-product-assurance-default"]
		},
		{
			"id": "conditional-govuk-design-system",
			"bundleId": "govuk-design-system",
			"traceLayer": "behavioural",
			"type": "conditional",
			"requiredSignals": ["ui-or-content-change"]
		},
		{
			"id": "conditional-cloudflare-core",
			"bundleId": "cloudflare-core-developer",
			"traceLayer": "behavioural",
			"type": "conditional",
			"requiredSignals": ["runtime-or-deployment-change"]
		},
		{
			"id": "conditional-airtable-api",
			"bundleId": "airtable-public-api-developer",
			"traceLayer": "behavioural",
			"type": "conditional",
			"requiredSignals": ["external-api-or-data-change"]
		},
		{
			"id": "conditional-mural-api",
			"bundleId": "mural-public-api-developer",
			"traceLayer": "behavioural",
			"type": "conditional",
			"requiredSignals": ["external-api-or-collaboration-change"]
		}
	]
}
