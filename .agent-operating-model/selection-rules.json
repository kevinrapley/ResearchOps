{
	"version": "1.3.0",
	"purpose": "Provide auditable structured rules for selecting checked-in canonical agent bundles from typed task signals before falling back to registry keyword evidence.",
	"rules": [
		{
			"id": "always-github-diamond",
			"bundleId": "github-diamond",
			"traceLayer": "operational",
			"type": "always",
			"requiredSignals": ["repository-affecting-task"]
		},
		{
			"id": "always-researchops-developer-control",
			"bundleId": "researchops-developer-control",
			"traceLayer": "operational",
			"type": "always",
			"requiredSignals": ["repository-affecting-task"]
		},
		{
			"id": "always-multi-functional-team",
			"bundleId": "multi-functional-team",
			"traceLayer": "operational",
			"type": "always",
			"requiredSignals": ["government-product-assurance-default"]
		},
		{
			"id": "conditional-govuk-design-system",
			"bundleId": "govuk-design-system",
			"traceLayer": "behavioural",
			"type": "conditional",
			"requiredSignals": ["ui-or-content-change"]
		},
		{
			"id": "conditional-cloudflare",
			"bundleId": "cloudflare",
			"traceLayer": "behavioural",
			"type": "conditional",
			"requiredSignals": ["runtime-or-deployment-change"]
		},
		{
			"id": "conditional-openai-platform",
			"bundleId": "openai-platform",
			"traceLayer": "behavioural",
			"type": "conditional",
			"requiredSignals": ["ai-model-or-openai-platform-change"]
		},
		{
			"id": "conditional-airtable-public-api",
			"bundleId": "airtable-public-api",
			"traceLayer": "behavioural",
			"type": "conditional",
			"requiredSignals": ["external-api-or-data-change"]
		},
		{
			"id": "conditional-mural-public-api",
			"bundleId": "mural-public-api",
			"traceLayer": "behavioural",
			"type": "conditional",
			"requiredSignals": ["external-api-or-collaboration-change"]
		}
	]
}
