{% extends "layouts/researchops.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}

{% block head %}
	<meta property="schema:name" content="Outcomes – Impact and ROI — ResearchOps">
	<meta property="schema:creator" content="Home Office ResearchOps Platform">
	<meta property="schema:dateModified" content="2026-06-02">
	<meta property="dcterms:language" content="en-GB">
	<link rel="stylesheet" href="/css/outcomes.css" media="screen">
	<link rel="modulepreload" href="/js/project-context.js">
	<link rel="modulepreload" href="/js/outcomes-page.js">
	<link rel="modulepreload" href="/components/impact-tracker.js">
{% endblock %}

{% block content %}
<div class="govuk-width-container">
	{{ govukBreadcrumbs({
		attributes: {
			id: "outcomes-breadcrumbs",
			typeof: "schema:BreadcrumbList"
		},
		items: [
			{
				text: "Projects",
				href: "/pages/projects/",
				attributes: {
					property: "schema:item",
					typeof: "schema:Thing"
				}
			},
			{
				text: "Project",
				href: "/pages/project-dashboard/?id=",
				attributes: {
					id: "breadcrumb-project",
					property: "schema:item",
					typeof: "schema:Thing"
				}
			},
			{
				text: "Impact & ROI"
			}
		]
	}) }}

	<header class="outcomes-hero" typeof="schema:ResearchProject" resource="#project">
		<p id="eyebrow-org" class="govuk-caption-l" property="schema:sourceOrganization" typeof="schema:Organization"></p>
		<h1 id="project-title" class="govuk-heading-l" property="schema:name">Impact & ROI</h1>
		<p id="project-subtitle" class="govuk-body-l" property="schema:description">Track how research insights influence decisions, delivery work and measurable outcomes.</p>
	</header>

	{{ govukInsetText({
		html: '<p class="govuk-body">Use impact records to connect research evidence to product, service and operational decisions. Do not record participant personal data in this area.</p>'
	}) }}

	<section id="impact-tracker" class="outcomes-tracker" data-project-id="" data-study-id="" aria-labelledby="impact-heading">
		<h2 id="impact-heading" class="govuk-heading-m">Add an impact record</h2>

		{{ govukErrorSummary({
			attributes: {
				id: "impact-error-summary",
				hidden: "hidden"
			},
			titleText: "There is a problem",
			errorList: []
		}) }}

		<div class="outcomes-form-layout">
			<form id="impact-form" class="outcomes-form" novalidate>
				<input id="impact-record-id" name="recordId" type="hidden" value="">

				{{ govukInput({
					id: "impact-insightId",
					name: "displayRef",
					classes: "govuk-input--width-20",
					label: {
						text: "Impact record reference"
					},
					hint: {
						text: "Auto-generated identifier for this impact record."
					},
					attributes: {
						readonly: "readonly",
						"data-guidance-key": "reference"
					}
				}) }}

				{{ govukInput({
					id: "impact-decisionLink",
					name: "decisionLink",
					type: "url",
					classes: "govuk-!-width-two-thirds",
					label: {
						text: "Decision link"
					},
					hint: {
						text: "Link to the decision this insight informed."
					},
					attributes: {
						inputmode: "url",
						"data-guidance-key": "decisionLink"
					}
				}) }}

				{{ govukInput({
					id: "impact-metricName",
					name: "metricName",
					classes: "govuk-!-width-two-thirds",
					label: {
						text: "Metric name"
					},
					hint: {
						text: "The metric being tracked."
					},
					attributes: {
						required: "required",
						"data-guidance-key": "metricName"
					}
				}) }}

				{{ govukRadios({
					name: "metricUnit",
					fieldset: {
						legend: {
							text: "Metric unit",
							classes: "govuk-fieldset__legend--s"
						}
					},
					hint: {
						text: "Use the same unit for baseline, target and actual."
					},
					attributes: {
						"data-guidance-key": "metricUnit"
					},
					items: [
						{
							value: "percentage",
							text: "Percentage"
						},
						{
							value: "count",
							text: "Count"
						},
						{
							value: "minutes",
							text: "Minutes"
						},
						{
							value: "days",
							text: "Days"
						},
						{
							value: "score",
							text: "Score"
						},
						{
							value: "cost",
							text: "Cost"
						},
						{
							value: "other",
							text: "Other"
						}
					]
				}) }}

				{{ govukRadios({
					name: "metricDirection",
					fieldset: {
						legend: {
							text: "Desired direction",
							classes: "govuk-fieldset__legend--s"
						}
					},
					hint: {
						text: "Describe how to interpret movement in the metric."
					},
					attributes: {
						"data-guidance-key": "metricDirection"
					},
					items: [
						{
							value: "increase",
							text: "Increase is better"
						},
						{
							value: "decrease",
							text: "Decrease is better"
						},
						{
							value: "range",
							text: "Stay within range is better"
						},
						{
							value: "not-directional",
							text: "Not directional"
						}
					]
				}) }}

				{{ govukDateInput({
					id: "impact-date",
					namePrefix: "recordedAt",
					fieldset: {
						legend: {
							text: "Date recorded",
							classes: "govuk-fieldset__legend--s"
						}
					},
					hint: {
						text: "For example, 2 6 2026."
					},
					attributes: {
						"data-guidance-key": "recordedAt"
					},
					items: [
						{
							name: "day",
							classes: "govuk-input--width-2"
						},
						{
							name: "month",
							classes: "govuk-input--width-2"
						},
						{
							name: "year",
							classes: "govuk-input--width-4"
						}
					]
				}) }}

				{{ govukInput({
					id: "impact-baseline",
					name: "baseline",
					type: "number",
					classes: "govuk-input--width-10",
					label: {
						text: "Baseline value"
					},
					hint: {
						text: "Value before the change."
					},
					attributes: {
						step: "0.01",
						inputmode: "decimal",
						"data-guidance-key": "baseline"
					}
				}) }}

				{{ govukInput({
					id: "impact-target",
					name: "target",
					type: "number",
					classes: "govuk-input--width-10",
					label: {
						text: "Target value"
					},
					hint: {
						text: "Expected value after the change."
					},
					attributes: {
						step: "0.01",
						inputmode: "decimal",
						"data-guidance-key": "target"
					}
				}) }}

				{{ govukInput({
					id: "impact-actual",
					name: "actual",
					type: "number",
					classes: "govuk-input--width-10",
					label: {
						text: "Actual value"
					},
					hint: {
						text: "Observed value after the change."
					},
					attributes: {
						step: "0.01",
						inputmode: "decimal",
						"data-guidance-key": "actual"
					}
				}) }}

				{{ govukRadios({
					name: "measurementWindow",
					fieldset: {
						legend: {
							text: "Measurement window",
							classes: "govuk-fieldset__legend--s"
						}
					},
					hint: {
						text: "When the actual value should be checked."
					},
					attributes: {
						"data-guidance-key": "measurementWindow"
					},
					items: [
						{
							value: "before-change",
							text: "Before change"
						},
						{
							value: "two-weeks",
							text: "2 weeks after change"
						},
						{
							value: "one-month",
							text: "1 month after change"
						},
						{
							value: "three-months",
							text: "3 months after change"
						},
						{
							value: "custom",
							text: "Custom"
						}
					]
				}) }}

				{{ govukRadios({
					name: "impactType",
					fieldset: {
						legend: {
							text: "Impact type",
							classes: "govuk-fieldset__legend--s"
						}
					},
					hint: {
						text: "What kind of change the research influenced."
					},
					attributes: {
						"data-guidance-key": "impactType"
					},
					items: [
						{
							value: "product",
							text: "Product"
						},
						{
							value: "service",
							text: "Service"
						},
						{
							value: "process",
							text: "Process"
						},
						{
							value: "strategy",
							text: "Strategy"
						},
						{
							value: "policy",
							text: "Policy"
						},
						{
							value: "operational",
							text: "Operational"
						},
						{
							value: "research-practice",
							text: "Research practice"
						}
					]
				}) }}

				{{ govukRadios({
					name: "impactScale",
					fieldset: {
						legend: {
							text: "Impact scale",
							classes: "govuk-fieldset__legend--s"
						}
					},
					hint: {
						text: "How widely the change applies."
					},
					attributes: {
						"data-guidance-key": "impactScale"
					},
					items: [
						{
							value: "feature",
							text: "Feature"
						},
						{
							value: "journey",
							text: "Journey"
						},
						{
							value: "service",
							text: "Service"
						},
						{
							value: "team",
							text: "Team"
						},
						{
							value: "cross-team",
							text: "Cross-team"
						},
						{
							value: "organisation-wide",
							text: "Organisation-wide"
						}
					]
				}) }}

				{{ govukRadios({
					name: "status",
					fieldset: {
						legend: {
							text: "Status",
							classes: "govuk-fieldset__legend--s"
						}
					},
					hint: {
						text: "Lifecycle status of the change."
					},
					attributes: {
						"data-guidance-key": "status"
					},
					items: [
						{
							value: "planned",
							text: "Planned"
						},
						{
							value: "in-progress",
							text: "In progress"
						},
						{
							value: "implemented",
							text: "Implemented"
						},
						{
							value: "measured",
							text: "Measured"
						},
						{
							value: "archived",
							text: "Archived"
						}
					]
				}) }}

				{{ govukTextarea({
					id: "impact-notes",
					name: "notes",
					classes: "govuk-!-width-two-thirds",
					value: "",
					rows: 3,
					label: {
						text: "Notes"
					},
					hint: {
						text: "Additional context or links to evidence. Do not include participant personal data."
					},
					attributes: {
						"data-guidance-key": "notes"
					}
				}) }}

				<div class="govuk-button-group">
					{{ govukButton({
						text: "Save impact record",
						type: "submit",
						attributes: {
							id: "impact-submit"
						}
					}) }}
					{{ govukButton({
						text: "Cancel edit",
						type: "button",
						classes: "govuk-button--secondary",
						attributes: {
							id: "impact-cancel-edit",
							hidden: "hidden"
						}
					}) }}
				</div>
			</form>

			<aside id="impact-guidance-panel" class="outcomes-guidance-panel" aria-labelledby="impact-guidance-title" aria-live="polite">
				<h2 id="impact-guidance-title" class="govuk-heading-m">Help with this field</h2>
				<p id="impact-guidance-body" class="govuk-body">Focus a field to see guidance on how to make the impact record useful and reusable.</p>
			</aside>
		</div>

		<section id="impact-records-section" class="outcomes-records" aria-labelledby="impact-records-heading">
			<h2 id="impact-records-heading" class="govuk-heading-m">Recorded impacts for this project</h2>
			<p id="impact-empty-state" class="govuk-body">Recorded impacts will appear here after you save the first impact record.</p>

			<div id="impact-table-wrap" class="outcomes-table-wrap" hidden>
				{{ govukTable({
					attributes: {
						id: "impact-table"
					},
					classes: "govuk-!-margin-top-6 outcomes-table",
					caption: "Recorded impacts for this project",
					captionClasses: "govuk-table__caption--m",
					head: [
						{
							text: "Reference"
						},
						{
							text: "Decision"
						},
						{
							text: "Metric"
						},
						{
							text: "Baseline",
							classes: "govuk-table__header--numeric"
						},
						{
							text: "Target",
							classes: "govuk-table__header--numeric"
						},
						{
							text: "Actual",
							classes: "govuk-table__header--numeric"
						},
						{
							text: "Type"
						}
					],
					rows: []
				}) }}
			</div>
		</section>
	</section>
</div>
{% endblock %}

{% block scripts %}
	<script type="module" src="/js/project-context.js"></script>
	<script type="module" src="/js/outcomes-page.js"></script>
	<script type="module" src="/components/impact-tracker.js"></script>
{% endblock %}
