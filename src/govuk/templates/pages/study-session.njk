{% extends "layouts/researchops.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "macros/daas-brand-panel.njk" import daasBrandPanel %}

{% set sessionPageScriptVersion = "study-session-card-sort-20260709-8" %}

{% block head %}
	<meta property="schema:name" content="Research session - ResearchOps">
	<meta property="schema:creator" content="Home Office ResearchOps Platform">
	<meta property="dcterms:language" content="en-GB">
	<link rel="stylesheet" href="/css/study-page.css" media="screen">
	<link rel="stylesheet" href="/css/study-session.css?v={{ sessionPageScriptVersion }}" media="screen">
	<link rel="stylesheet" href="/css/daas-brand-panel.css?v=leds-brand-panel-20260624" media="screen">
	<link rel="modulepreload" href="/js/daas-brand-panel.js?v=leds-brand-panel-20260624">
	<link rel="modulepreload" href="/components/session-controller.js?v={{ sessionPageScriptVersion }}">
	<link rel="stylesheet" href="/css/study-card-sort.css?v={{ sessionPageScriptVersion }}" media="screen">
	<link rel="modulepreload" href="/components/session-consent-controller.js?v={{ sessionPageScriptVersion }}">
	<link rel="modulepreload" href="/components/session-card-sort-controller.js?v={{ sessionPageScriptVersion }}">
{% endblock %}

{% block content %}
<div class="govuk-width-container study-session-page" data-study-subpage-template="session">
	{{ govukBreadcrumbs({
		items: [
			{ text: "Projects", href: "/pages/projects/" },
			{ text: "Project", href: "#", attributes: { id: "breadcrumb-project" } },
			{ text: "Study", href: "#", attributes: { id: "breadcrumb-study" } },
			{ text: "Session" }
		]
	}) }}

	{{ daasBrandPanel() }}

	{{ govukErrorSummary({
		titleText: "There is a problem",
		errorList: [
			{ text: "Participants could not be loaded.", href: "#participant-select" }
		],
		attributes: { id: "session-error-summary", hidden: "hidden" }
	}) }}

	<div id="session-entity" typeof="schema:Event" resource="#session" hidden>
		<meta property="schema:identifier" content="">
	</div>

	<header class="study-session-hero govuk-!-margin-bottom-6">
		<p id="study-title" class="govuk-caption-m">Study</p>
		<h1 class="govuk-heading-l">Run a research session</h1>
		<p id="page-desc" class="govuk-body-l govuk-!-width-two-thirds">
			Select a participant, check consent, control the timer and capture timestamped fieldnotes as the session
			unfolds.
		</p>
	</header>

	<section class="study-session-section govuk-!-margin-bottom-8" aria-labelledby="participant-picker-title">
		<h2 id="participant-picker-title" class="govuk-heading-m">Select participant</h2>

		{{ govukSelect({
			id: "participant-select",
			name: "participantSelect",
			classes: "govuk-!-width-two-thirds",
			label: { text: "Participant" },
			hint: { text: "This list is populated from participants scheduled to the current study." },
			items: [
				{ value: "", text: "Choose a participant", selected: true }
			]
		}) }}

		<div class="govuk-grid-row study-session-summary-grid">
			<div class="govuk-grid-column-one-half">
				{{ govukDetails({
					summaryText: "Participant details",
					html: '<dl class="govuk-summary-list study-session-data-list" id="participant-details"></dl>',
					attributes: { "data-flux-key": "button.study.participant-details", "data-flux-role": "control" }
				}) }}
			</div>

			<div class="govuk-grid-column-one-half">
				{{ govukDetails({
					summaryText: "Consent summary",
					html: '<dl class="govuk-summary-list study-session-data-list" id="consent-summary"></dl>',
					attributes: { "data-flux-key": "button.study.consent-summary", "data-flux-role": "control" }
				}) }}
			</div>
		</div>
	</section>

	<section class="study-session-section govuk-!-margin-bottom-8" aria-labelledby="controls-title">
		<h2 id="controls-title" class="govuk-heading-m">Session controls</h2>

		{{ govukWarningText({
			html: '<span id="consent-gate-message-body">Choose a participant to review consent status.</span>',
			iconFallbackText: "Warning",
			classes: "study-session-consent-gate",
			attributes: { id: "consent-gate-message", role: "alert", hidden: "hidden" }
		}) }}

		<p id="consent-gate-actions" class="govuk-button-group study-session-consent-gate-actions" hidden>
			{{ govukButton({
				text: "Manage participant consent",
				href: "/pages/study/participant-consent/",
				classes: "govuk-button--secondary",
				attributes: { id: "manage-participant-consent-link" }
			}) }}
		</p>

		<div class="govuk-button-group study-session-controls">
			{{ govukButton({ text: "Start", type: "button", attributes: { id: "btn-start" } }) }}
			{{ govukButton({
				text: "Pause",
				type: "button",
				classes: "govuk-button--secondary",
				disabled: true,
				attributes: { id: "btn-pause" }
			}) }}
			{{ govukButton({
				text: "Stop",
				type: "button",
				classes: "govuk-button--warning",
				disabled: true,
				attributes: { id: "btn-stop" }
			}) }}

			<p
				class="study-session-timer govuk-body govuk-!-font-weight-bold"
				role="timer"
				aria-live="polite"
				aria-atomic="true"
			>
				<span id="timer-display">00:00:00</span>
			</p>
		</div>
	</section>

	<section class="study-session-section govuk-!-margin-bottom-8" id="card-sort-section" aria-labelledby="card-sort-title" hidden>
		<h2 id="card-sort-title" class="govuk-heading-m">Card sort</h2>
		<p id="card-sort-type-line" class="govuk-body govuk-!-width-two-thirds"></p>

		{{ govukWarningText({
			html: 'This study does not have a card sort set up yet.
				<a id="card-sort-setup-link" class="govuk-link" href="/pages/study/card-sort/">Prepare the card sort</a>
				before running this session.',
			iconFallbackText: "Warning",
			attributes: { id: "card-sort-setup-warning", hidden: "hidden" }
		}) }}

		<div id="card-sort-instructions" class="card-sort-instructions" hidden>
			<h3 class="govuk-heading-s govuk-!-margin-bottom-1">Instructions for the participant</h3>
			<p id="card-sort-instructions-text" class="govuk-body govuk-!-margin-bottom-0"></p>
		</div>

		<div class="card-sort-toolbar">
			<p id="card-sort-progress" class="govuk-body card-sort-progress" aria-live="polite"></p>
			{{ govukButton({ text: "Mark card sort complete", type: "button", attributes: { id: "btn-complete-card-sort" } }) }}
			{{ govukButton({
				text: "Reset sort",
				type: "button",
				classes: "govuk-button--warning",
				attributes: { id: "btn-reset-card-sort" }
			}) }}
			<p id="card-sort-save-status" class="govuk-hint card-sort-save-status" aria-live="polite"></p>
		</div>

		<div id="card-sort-reset-confirmation" class="card-sort-reset-confirmation" hidden>
			<p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-2">Reset this card sort?</p>
			<p class="govuk-body-s govuk-!-margin-bottom-3">This moves all cards back to the tray and removes participant-created groups and cards.</p>
			<div class="govuk-button-group">
				{{ govukButton({
					text: "Yes, reset card sort",
					type: "button",
					classes: "govuk-button--warning",
					attributes: { id: "btn-confirm-reset-card-sort" }
				}) }}
				{{ govukButton({
					text: "Cancel",
					type: "button",
					classes: "govuk-button--secondary",
					attributes: { id: "btn-cancel-reset-card-sort" }
				}) }}
			</div>
		</div>

		<div id="card-sort-board" class="card-sort-board">
			<div class="card-sort-tray" aria-labelledby="card-sort-tray-title">
				<h3 id="card-sort-tray-title" class="govuk-heading-s card-sort-tray__title">Cards to sort</h3>
				<ol id="card-sort-tray-list" class="card-sort-card-list" aria-label="Unsorted cards"></ol>

				<form id="card-sort-add-card-form" class="card-sort-add-form" hidden>
					<label class="govuk-label govuk-visually-hidden" for="card-sort-new-card-input">New card label</label>
					<input class="govuk-input" id="card-sort-new-card-input" type="text" placeholder="Add a card">
					<button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">Add card</button>
				</form>
			</div>

			<div class="card-sort-groups" aria-labelledby="card-sort-groups-title">
				<h3 id="card-sort-groups-title" class="govuk-heading-s card-sort-groups__title">Groups</h3>
				<div id="card-sort-groups-grid" class="card-sort-groups__grid"></div>

				<form id="card-sort-add-group-form" class="card-sort-add-form" hidden>
					<label class="govuk-label govuk-visually-hidden" for="card-sort-new-group-input">New group name</label>
					<input class="govuk-input" id="card-sort-new-group-input" type="text" placeholder="Add a group">
					<button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">Add group</button>
				</form>
			</div>
		</div>
	</section>

	<section class="study-session-section" aria-labelledby="notes-title">
		<h2 id="notes-title" class="govuk-heading-m">Fieldnotes</h2>
		<p class="govuk-body govuk-!-width-two-thirds">
			Capture ambient notes without leaving the participant. Type, press Enter, and the note lands in the session
			record with a timestamp. Shorthand prefixes set the category as you type.
		</p>

		<div class="govuk-grid-row study-session-note-options">
			<div class="govuk-grid-column-one-half">
				{{ govukSelect({
					id: "framework",
					name: "framework",
					label: { text: "Note framework" },
					hint: { text: "The framework sets the note categories and their shorthand prefixes." },
					items: [
						{ value: "fieldnotes", text: "Fieldnotes", selected: true },
						{ value: "aeiou", text: "AEIOU" },
						{ value: "poems", text: "POEMS" }
					]
				}) }}
			</div>
			<div class="govuk-grid-column-one-half">
				{{ govukSelect({
					id: "note-kind",
					name: "noteKind",
					label: { text: "Category" },
					hint: { text: "Set automatically by a shorthand prefix, or choose one here." },
					items: [
						{ value: "observation", text: "Observation", selected: true }
					]
				}) }}
			</div>
		</div>

		<div class="study-session-capture" id="note-capture">
			{{ govukTextarea({
				id: "note-input",
				name: "noteInput",
				value: "",
				rows: 2,
				label: { text: "Capture a note", classes: "govuk-label--s" },
				hint: {
					text: "Press Enter to save, Shift and Enter for a new line. Use #tags for themes and @refs for participants.
						Do not enter participant personal data unless it is necessary for the research record."
				}
			}) }}

			<p class="govuk-body-s study-session-shortcuts" id="note-shortcuts" aria-label="Shorthand prefixes"></p>

			<div class="govuk-button-group">
				{{ govukButton({ text: "Save note", type: "button", disabled: true, attributes: { id: "btn-save-note" } }) }}
				<p id="note-timestamps" class="govuk-hint study-session-note-status" aria-live="polite"></p>
			</div>
		</div>

		{{ govukDetails({
			summaryText: "How shorthand prefixes work",
			html: '<p class="govuk-body">Start a note with a prefix and a space to set its category, for example
				<code>q</code> for a quote in the Fieldnotes framework. The prefix is removed from the saved note.
				Notes without a prefix use the category selected above.</p>',
			attributes: { "data-flux-key": "button.study.note-prefix-help", "data-flux-role": "control" }
		}) }}

		<section id="saved-notes-section" aria-labelledby="saved-notes-title" class="govuk-!-margin-top-6" hidden>
			<h3 id="saved-notes-title" class="govuk-heading-s">Session notes</h3>

			<div class="study-session-note-toolbar">
				<div class="study-session-note-filters" id="note-filters" role="group" aria-label="Filter notes by category"></div>
				<p class="govuk-body-s study-session-note-count" id="notes-count" aria-live="polite"></p>
				{{ govukButton({
					text: "Export notes (Markdown)",
					type: "button",
					classes: "govuk-button--secondary",
					attributes: { id: "btn-export-notes" }
				}) }}
			</div>

			<ol id="notes-list" class="govuk-list study-session-notes-list"></ol>
		</section>
	</section>
</div>
{% endblock %}

{% block scripts %}
	<script type="module" src="/js/daas-brand-panel.js?v=leds-brand-panel-20260624"></script>
	<script type="module" src="/components/session-controller.js?v={{ sessionPageScriptVersion }}"></script>
	<script type="module" src="/components/session-consent-controller.js?v={{ sessionPageScriptVersion }}"></script>
	<script type="module" src="/components/session-card-sort-controller.js?v={{ sessionPageScriptVersion }}"></script>
{% endblock %}
