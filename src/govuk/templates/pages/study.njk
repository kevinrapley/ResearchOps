{% extends "layouts/researchops.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/task-list/macro.njk" import govukTaskList %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "macros/daas-brand-panel.njk" import daasBrandPanel %}
{% from "macros/sourcebook-context.njk" import SourcebookContext %}
{% from "macros/sourcebook-evidence-ledger.njk" import SourcebookEvidenceLedger %}
{% from "macros/sourcebook-gate.njk" import SourcebookGate %}

{% set studyReadinessScriptVersion = "study-session-canonical-20260707-1" %}

{% block head %}
	<meta property="schema:name" content="Study — ResearchOps">
	<meta property="schema:creator" content="Home Office ResearchOps Platform">
	<meta property="schema:dateModified" content="2026-06-03">
	<meta property="dcterms:language" content="en-GB">
	<link rel="stylesheet" href="/css/govuk/govuk-forms.css" media="screen">
	<link rel="stylesheet" href="/css/govuk/govuk-tables.css" media="screen">
	<link rel="stylesheet" href="/css/sourcebook-components.css" media="screen">
	<link rel="stylesheet" href="/css/study-page.css" media="screen">
	<link rel="stylesheet" href="/css/daas-brand-panel.css?v=leds-brand-panel-20260624" media="screen">
	<link rel="modulepreload" href="/js/daas-brand-panel.js?v=leds-brand-panel-20260624">
	<link rel="modulepreload" href="/js/study-page.js?v={{ studyReadinessScriptVersion }}">
	<link rel="modulepreload" href="/pages/study/study-desc-controller.js">
{% endblock %}

{% block content %}
<div class="govuk-width-container study-page" data-study-template="govuk-task-list">
	{{ govukBreadcrumbs({
		attributes: {
			id: "study-breadcrumbs",
			typeof: "schema:BreadcrumbList"
		},
		items: [
			{
				text: "Projects",
				href: "/pages/projects/",
				attributes: {
					property: "schema:item",
					typeof: "schema:Thing"
				}
			},
			{
				text: "Project",
				href: "#",
				attributes: {
					id: "breadcrumb-project",
					property: "schema:item",
					typeof: "schema:Thing"
				}
			},
			{
				text: "Study"
			}
		]
	}) }}

	{{ daasBrandPanel() }}

	{{ govukErrorSummary({
		attributes: {
			id: "study-error",
			tabindex: "-1",
			hidden: "hidden",
			"aria-hidden": "true"
		},
		titleText: "There is a problem loading this study",
		errorList: [
			{
				html: '<span id="study-error-message">Could not load the study.</span>',
				href: "#study-breadcrumbs"
			}
		]
	}) }}

	<div class="study-action-bar govuk-button-group">
		{{ govukButton({
			text: "Edit study",
			href: "#",
			classes: "govuk-button--secondary",
			attributes: {
				id: "edit-study"
			}
		}) }}
	</div>

	<header class="study-hero govuk-!-margin-bottom-6" typeof="schema:ResearchProject" resource="#study">
		<p id="study-eyebrow" class="govuk-caption-m">Project</p>
		<h1 id="study-title" class="govuk-heading-l" property="schema:name">Study</h1>
		<div id="desc-view-wrap" class="study-description" property="schema:description">
			<div id="description" class="govuk-body">—</div>
			<div class="study-description__actions">
				{{ govukButton({
					text: "Edit description",
					type: "button",
					classes: "govuk-button--secondary",
					attributes: {
						id: "btn-edit-desc"
					}
				}) }}
			</div>
		</div>

		<form id="desc-editor" class="study-description-editor" hidden>
			{{ govukTextarea({
				id: "desc-input",
				name: "description",
				classes: "govuk-!-width-two-thirds",
				value: "",
				rows: 8,
				label: {
					text: "Description"
				},
				hint: {
					text: "You can use Markdown. Do not include participant personal data."
				},
				attributes: {
					spellcheck: "true",
					autocomplete: "off"
				}
			}) }}

			{{ govukDetails({
				summaryText: "Markdown cheat sheet",
				html: '<p class="govuk-body">You can use headings, bold or italic text, links, lists, inline code and code blocks. HTML and images are not supported.</p>'
			}) }}

			<div class="govuk-button-group">
				{{ govukButton({
					text: "Save",
					type: "submit",
					attributes: {
						id: "btn-save-desc"
					}
				}) }}
				{{ govukButton({
					text: "Cancel",
					type: "button",
					classes: "govuk-button--secondary",
					attributes: {
						id: "desc-cancel"
					}
				}) }}
			</div>
		</form>
		<p id="desc-status" class="govuk-body-s" role="status" aria-live="polite" aria-atomic="true"></p>
	</header>

	<div class="govuk-grid-row study-overview-grid">
		<div class="govuk-grid-column-one-half">
			<section class="study-key-information govuk-!-margin-bottom-8" aria-labelledby="study-key-information-title">
				<h2 id="study-key-information-title" class="govuk-heading-m">Study details</h2>
				{{ govukSummaryList({
					classes: "study-summary-list",
					rows: [
						{
							key: { text: "Method" },
							value: { html: '<span id="kv-method">–</span>' }
						},
						{
							key: { text: "Status" },
							value: { html: '<span id="kv-status">–</span>' }
						},
						{
							key: { text: "Study ID" },
							value: { html: '<span id="kv-studyid">–</span>' }
						}
					]
				}) }}
			</section>

			<section class="study-section study-session-gate-section govuk-!-margin-bottom-8" aria-labelledby="study-session-gate-title">
				<h2 id="study-session-gate-title" class="govuk-heading-m">Before you can begin a session</h2>
				{{ govukInsetText({
					classes: "study-session-gate",
					html: '<h3 id="study-session-gate-summary" class="govuk-heading-s">Checking study readiness</h3><p id="study-session-gate-message" class="govuk-body">Checking the required setup tasks before fieldwork can begin.</p><ul id="study-session-blockers" class="govuk-list govuk-list--bullet"><li>Checking readiness tasks.</li></ul><div id="study-session-action" hidden>' + govukButton({
						text: "Begin session",
						href: "#",
						classes: "study-session-button",
						attributes: {
							id: "link-session",
							hidden: "hidden"
						}
					}) + '</div>'
				}) }}
				{{ SourcebookGate(sourcebookGate) }}
			</section>
		</div>

		<aside class="govuk-grid-column-one-half study-readiness-column" aria-labelledby="study-readiness-title">
			<section class="study-readiness-section govuk-!-margin-bottom-8">
				<h2 id="study-readiness-title" class="govuk-heading-m">Study readiness</h2>
				{{ govukTaskList({
					idPrefix: "study-readiness",
					classes: "study-readiness-task-list",
					items: [
						{
							title: { text: "Description" },
							hint: { html: '<span id="study-readiness-description-hint" class="study-readiness-hint">The study has a description.</span>' },
							status: { html: '<strong id="study-readiness-description-status" class="govuk-tag govuk-tag--green study-readiness-status">Ready</strong>' }
						},
						{
							title: { text: "Status" },
							hint: { html: '<span id="study-readiness-status-hint" class="study-readiness-hint">Study status is Planned.</span>' },
							status: { html: '<strong id="study-readiness-status-status" class="govuk-tag govuk-tag--green study-readiness-status">Ready</strong>' }
						},
						{
							title: { text: "Ethics and research risk" },
							hint: { html: '<span id="study-readiness-ethics-risk-hint" class="study-readiness-hint">Assess ethical risk before recruitment or fieldwork.</span>' },
							status: { html: '<strong id="study-readiness-ethics-risk-status" class="govuk-tag govuk-tag--yellow study-readiness-status">Action needed</strong>' }
						},
						{
							title: { text: "Participants" },
							hint: { html: '<span id="study-readiness-participants-hint" class="study-readiness-hint">Add or review participants for this study.</span>' },
							status: { html: '<strong id="study-readiness-participants-status" class="govuk-tag govuk-tag--yellow study-readiness-status">Action needed</strong>' }
						},
						{
							title: { text: "Discussion guide" },
							hint: { html: '<span id="study-readiness-guide-hint" class="study-readiness-hint">Create or review the discussion guide.</span>' },
							status: { html: '<strong id="study-readiness-guide-status" class="govuk-tag govuk-tag--yellow study-readiness-status">Action needed</strong>' }
						},
						{
							title: { text: "Consent materials" },
							hint: { html: '<span id="study-readiness-consent-materials-hint" class="study-readiness-hint">A published consent form is available for this study.</span>' },
							status: { html: '<strong id="study-readiness-consent-materials-status" class="govuk-tag govuk-tag--green study-readiness-status">Ready</strong>' }
						},
						{
							title: { text: "Participant consent" },
							hint: { html: '<span id="study-readiness-participant-consent-hint" class="study-readiness-hint">Record required participant consent before running sessions.</span>' },
							status: { html: '<strong id="study-readiness-participant-consent-status" class="govuk-tag govuk-tag--yellow study-readiness-status">Action needed</strong>' }
						},
						{
							title: { text: "Session workspace" },
							hint: { html: '<span id="study-readiness-session-hint" class="study-readiness-hint">Complete study readiness tasks before beginning a session.</span>' },
							status: { html: '<strong id="study-readiness-session-status" class="govuk-tag govuk-tag--grey study-readiness-status">Not available yet</strong>' }
						}
					]
				}) }}
			</section>

			<section class="study-evidence-summary-section govuk-!-margin-bottom-8" aria-labelledby="study-evidence-summary-title">
				<h2 id="study-evidence-summary-title" class="govuk-heading-m">Evidence state summary</h2>
				<p id="study-evidence-summary-intro" class="govuk-body">Checking captured study evidence and synthesis progress.</p>
				{{ govukSummaryList({
					classes: "study-evidence-summary-list",
					rows: [
						{
							key: { text: "Evidence notes" },
							value: { html: '<span id="study-evidence-count">Checking evidence notes.</span>' }
						},
						{
							key: { text: "Synthesis state" },
							value: { html: '<span id="study-evidence-state">Checking synthesis state.</span>' }
						},
						{
							key: { text: "Next action" },
							value: { html: '<span id="study-evidence-next-action">Wait for the evidence summary to load.</span>' }
						}
					]
				}) }}
			</section>
		</aside>
	</div>

	<section class="study-section study-section--flush govuk-!-margin-bottom-8" aria-labelledby="study-setup-title">
		<h2 id="study-setup-title" class="govuk-heading-m">Study setup tasks</h2>
		{{ govukTaskList({
			idPrefix: "study-setup",
			classes: "study-setup-task-list",
			items: [
					{
						title: { html: '<a id="link-ethics-risk" class="govuk-link govuk-task-list__link" href="/pages/study/ethics-risk/">Assess ethics and research risk</a>' },
						hint: { html: 'Answer factual questions so ResearchOps can identify sensitive research triggers before recruitment or fieldwork. <span class="study-sourcebook-reference">Sourcebook: <a class="govuk-link" href="/pages/sourcebook/governance/#govern-2-1-1">GOVERN 2.1.1</a></span>' },
						status: { html: '<strong id="study-setup-ethics-risk-status" class="govuk-tag govuk-tag--yellow">Action needed</strong>' }
					},
					{
						title: { html: '<a id="link-consent-forms" class="govuk-link govuk-task-list__link" href="#">Create consent forms</a>' },
						hint: { html: 'Create or review Markdown and Mustache consent form templates for this study. <span class="study-sourcebook-reference">Sourcebook: <a class="govuk-link" href="/pages/sourcebook/recruitment-and-administration/#rec-admn-3-1-1">REC-ADMN 3.1.1</a></span>' },
						status: { html: '<strong id="study-setup-consent-forms-status" class="govuk-tag govuk-tag--yellow">Action needed</strong>' }
					},
					{
						title: { html: '<a id="link-participant-consent" class="govuk-link govuk-task-list__link" href="#">Manage participant consent</a>' },
						hint: { html: 'Record, review or withdraw participant consent for this study. <span class="study-sourcebook-reference">Sourcebook: <a class="govuk-link" href="/pages/sourcebook/recruitment-and-administration/#rec-admn-3-1-1">REC-ADMN 3.1.1</a></span>' },
						status: { html: '<strong id="study-setup-participant-consent-status" class="govuk-tag govuk-tag--yellow">Action needed</strong>' }
					},
					{
						title: { html: '<a id="link-participants" class="govuk-link govuk-task-list__link" href="#">Schedule participants</a>' },
						hint: { html: 'Add or review participants for this study. <span class="study-sourcebook-reference">Sourcebook: <a class="govuk-link" href="/pages/sourcebook/governance/#govern-2-1-1">GOVERN 2.1.1</a></span>' },
						status: { html: '<strong id="study-setup-participants-status" class="govuk-tag govuk-tag--yellow">Action needed</strong>' }
					},
					{
						title: { html: '<a id="link-guides" class="govuk-link govuk-task-list__link" href="#">Create or manage discussion guides</a>' },
						hint: { html: 'Create or review the guide before running a session. <span class="study-sourcebook-reference">Sourcebook: <a class="govuk-link" href="/pages/sourcebook/scope/#scope-2-1-1">SCOPE 2.1.1</a></span>' },
						status: { html: '<strong id="study-setup-guide-status" class="govuk-tag govuk-tag--yellow">Action needed</strong>' }
					},
					{
						title: { html: '<a id="link-note-takers-observers" class="govuk-link govuk-task-list__link" href="#">Add note takers and observers</a>' },
						hint: { html: '<span id="study-setup-support-hint">Confirm who, if anyone, will join sessions beyond the lead researcher.</span> <span class="study-sourcebook-reference">Sourcebook: <a class="govuk-link" href="/pages/sourcebook/environment/#enviro-1-1-2">ENVIRO 1.1.2</a></span>' },
						status: { html: '<strong id="study-setup-support-status" class="govuk-tag govuk-tag--yellow">Action needed</strong>' }
					}
				]
		}) }}
	</section>

	{{ SourcebookContext(sourcebookContext) }}

	<section class="study-section study-section--flush govuk-!-margin-bottom-8" aria-labelledby="study-analysis-title">
		<h2 id="study-analysis-title" class="govuk-heading-m">Study analysis tasks</h2>
		{{ govukTaskList({
			idPrefix: "study-analysis",
			classes: "study-analysis-task-list",
			items: [
				{
					title: { html: '<a id="link-synthesis" class="govuk-link govuk-task-list__link" href="#">Synthesise study evidence</a>' },
					hint: { html: '<span id="study-analysis-synthesis-hint">Group evidence notes into working cluster groupings and create traceable study-level themes.</span>' },
					status: { html: '<strong id="study-analysis-synthesis-status" class="govuk-tag govuk-tag--grey">Available when evidence is captured</strong>' }
				}
			]
		}) }}
	</section>

	{{ govukDetails({
		classes: "study-sourcebook-evidence-details govuk-!-margin-bottom-8",
		summaryText: "Sourcebook evidence record",
		html: SourcebookEvidenceLedger(sourcebookEvidenceLedger)
	}) }}
</div>
{% endblock %}

{% block scripts %}
	<script type="module" src="/js/daas-brand-panel.js?v=leds-brand-panel-20260624"></script>
	<script type="module" src="/js/study-page.js?v={{ studyReadinessScriptVersion }}"></script>
	<script type="module" src="/pages/study/study-desc-controller.js"></script>
{% endblock %}
