{% extends "layouts/researchops.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "macros/daas-brand-panel.njk" import daasBrandPanel %}

{% set studyPageScriptVersion = "study-guides-delete-confirmation-20260605" %}

{% block head %}
	<meta property="schema:name" content="Discussion guides - ResearchOps">
	<link rel="stylesheet" href="/css/govuk/govuk-forms.css" media="screen">
	<link rel="stylesheet" href="/css/govuk/govuk-tables.css" media="screen">
	<link rel="stylesheet" href="/css/guides.css" media="screen">
	<link rel="stylesheet" href="/css/daas-brand-panel.css?v=20260616" media="screen">
	<link rel="modulepreload" href="/js/study-route-context.js">
	<link rel="modulepreload" href="/js/daas-brand-panel.js?v=20260616">
	<link rel="modulepreload" href="/js/study-guides-context.js">
	<link rel="modulepreload" href="/js/guides-route-loader.js?v={{ studyPageScriptVersion }}">
	<!-- /components/guides/guides-page.js -->
{% endblock %}

{% block content %}
<div class="govuk-width-container study-guides-page" data-study-subpage-template="guides">
	{{ govukBreadcrumbs({
		items: [
			{ text: "Projects", href: "/pages/projects/" },
			{ text: "Project", href: "#", attributes: { id: "breadcrumb-project" } },
			{ text: "Study", href: "#", attributes: { id: "breadcrumb-study" } },
			{ text: "Guides" }
		]
	}) }}

	{{ daasBrandPanel() }}

	{{ govukNotificationBanner({
		titleText: "Important",
		html: '<p class="govuk-notification-banner__heading">Study details could not be loaded. Some saved guide data may be unavailable.</p>',
		attributes: { id: "study-context-warning", hidden: "hidden" }
	}) }}

	<header class="guides-header">
		<p id="study-title" class="govuk-caption-m" data-bind="study.title">Study</p>
		<h1 class="govuk-heading-l">Discussion guides</h1>
		<p class="govuk-body-l guides-header__lead">Create, review and publish discussion guides for this study.</p>
		<div class="govuk-button-group">
			{{ govukButton({
				text: "Draft a guide",
				type: "button",
				classes: "govuk-button--secondary",
				attributes: { id: "btn-new" }
			}) }}
		</div>
	</header>

	<section id="guides-list-section" class="guides-section" aria-labelledby="guides-list-title">
		<h2 id="guides-list-title" class="govuk-heading-m">Guides for this study</h2>
		<p class="govuk-body">Review saved guides, open a draft or check which guide has been published for fieldwork.</p>
		<div id="guides-empty" class="guides-empty-state govuk-inset-text" hidden>
			<h3 class="govuk-heading-s">No guides yet</h3>
			<p class="govuk-body">Draft a discussion guide in the editor, save it as a draft, then publish it when it is ready to use for fieldwork.</p>
		</div>
		<div id="guides-table-wrap" class="table-wrap">
			<table id="guides-table" class="govuk-table">
				<caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Discussion guides for this study</caption>
				<thead class="govuk-table__head">
					<tr class="govuk-table__row">
						<th class="govuk-table__header" scope="col">Guide</th>
						<th class="govuk-table__header" scope="col">Status</th>
						<th class="govuk-table__header" scope="col">Version</th>
						<th class="govuk-table__header" scope="col">Last updated</th>
						<th class="govuk-table__header" scope="col">Owner</th>
						<th class="govuk-table__header" scope="col"><span class="govuk-visually-hidden">Actions</span></th>
					</tr>
				</thead>
				<tbody id="guides-tbody" class="govuk-table__body">
					<tr class="govuk-table__row">
						<td class="govuk-table__cell" colspan="6">Loading guides.</td>
					</tr>
				</tbody>
			</table>
		</div>
	</section>

	<section id="editor-section" class="guides-section editor" aria-labelledby="guide-editor-title">
		<h2 id="guide-editor-title" class="govuk-heading-m">Guide editor</h2>
		<p class="govuk-body">Write the guide source, check the preview and save the guide before publishing it for sessions.</p>

		{{ govukErrorSummary({
			titleText: "There is a problem",
			errorList: [],
			attributes: { id: "guide-error-summary", hidden: "hidden" }
		}) }}

		{{ govukInput({
			id: "guide-title",
			name: "guideTitle",
			classes: "govuk-input--width-20 editor__title-field",
			label: { text: "Guide title", classes: "govuk-label--s" },
			attributes: { autocomplete: "off" }
		}) }}

		<p class="govuk-body-s guides-editor-status">Status: <span id="guide-status" aria-live="polite">draft</span></p>

		<div class="editor__toolbar" aria-label="Guide editor tools">
			<div class="govuk-button-group editor__toolbar-group">
			{{ govukButton({ text: "Insert pattern", type: "button", classes: "govuk-button--secondary", attributes: { id: "btn-insert-pattern" } }) }}
				{{ govukButton({ text: "Variables", type: "button", classes: "govuk-button--secondary", attributes: { id: "btn-variables" } }) }}
			</div>
			<div class="govuk-button-group editor__toolbar-group">
				{{ govukButton({ text: "Save draft", type: "button", classes: "govuk-button--secondary", attributes: { id: "btn-save" } }) }}
				{{ govukButton({ text: "Publish guide", type: "button", classes: "govuk-button--secondary", attributes: { id: "btn-publish" } }) }}
			</div>
		</div>

		<aside id="drawer-patterns" class="drawer" hidden aria-labelledby="drawer-patterns-title" tabindex="-1">
			<h2 id="drawer-patterns-title" class="govuk-heading-m">Patterns</h2>
			<div class="govuk-button-group drawer__actions">
				<button class="govuk-button govuk-button--secondary" id="btn-new-pattern" type="button" hidden>Create pattern</button>
				<button id="drawer-patterns-close" class="govuk-button govuk-button--secondary" type="button">Close</button>
			</div>
			{{ govukInput({
				id: "pattern-search",
				name: "patternSearch",
				label: { text: "Search patterns", classes: "govuk-label--s" },
				attributes: { autocomplete: "off" }
			}) }}
			<ul id="pattern-list" class="govuk-list pattern-list"></ul>
			<div id="pattern-tray" class="pattern-tray" hidden></div>
		</aside>

		<aside id="drawer-variables" class="drawer" hidden aria-labelledby="drawer-variables-title" tabindex="-1">
			<h2 id="drawer-variables-title" class="govuk-heading-m">Variables</h2>
			<p class="govuk-body">Manage reusable variables for this discussion guide.</p>
			<form id="variables-form" novalidate></form>
		</aside>

		<div class="govuk-grid-row editor__split">
			<div class="govuk-grid-column-one-half code-editor">
				<div id="guide-source-highlight" class="code-editor__highlight" aria-hidden="true"><code id="guide-source-code"></code></div>
				{{ govukTextarea({
					id: "guide-source",
					name: "guideSource",
					classes: "code-editor__textarea",
					rows: 18,
					value: "",
					label: { text: "Guide source", classes: "govuk-label--s" },
					hint: { text: "Use Markdown and ResearchOps variables to prepare the discussion guide." },
					spellcheck: true
				}) }}
			</div>
			<div class="govuk-grid-column-one-half">
				<div class="preview__header">
					<h3 class="govuk-heading-s preview__title">Preview</h3>
					<p class="govuk-hint preview__hint">Check how the discussion guide will read before saving or publishing it.</p>
				</div>
				<div class="preview">
					<div id="guide-preview" class="govuk-body"></div>
				</div>
			</div>
		</div>

		<p id="lint-output" class="govuk-body-s guides-lint-output" aria-live="polite">No guide checks have run yet.</p>

		{{ govukDetails({
			summaryText: "What to include in a discussion guide",
			html: '<p class="govuk-body">Include an opening script, consent reminders, core questions, prompts and a closing section. Keep personal data out of the guide unless it is needed to run the session.</p>'
		}) }}
	</section>
	<div class="govuk-button-group actions-row"></div>
	<div id="sr-live" class="govuk-visually-hidden" aria-live="polite"></div>
</div>
{% endblock %}

{% block scripts %}
	<script type="module" src="/js/daas-brand-panel.js?v=20260616"></script>
	<script type="module" src="/js/guides-route-loader.js?v={{ studyPageScriptVersion }}"></script>
{% endblock %}
