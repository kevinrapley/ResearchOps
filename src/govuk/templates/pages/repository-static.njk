{% extends "layouts/researchops.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block head %}
	<link rel="stylesheet" href="/css/repository.css?v=repository-api-20260607" media="screen">
	{% if detailRoute %}
	<link rel="modulepreload" href="/js/repository-artefact-page.js?v=repository-api-20260607b">
	{% endif %}
	{% if browseType or candidateRoute %}
	<link rel="modulepreload" href="/js/repository-static-page.js?v=repository-api-20260607b">
	{% endif %}
{% endblock %}

{% block content %}
<div class="govuk-width-container repository-page">
	{{ govukBreadcrumbs({
		attributes: {
			id: "repository-breadcrumbs",
			typeof: "schema:BreadcrumbList"
		},
		items: [
			{
				text: "Home",
				href: "/",
				attributes: {
					property: "schema:item",
					typeof: "schema:Thing"
				}
			},
			{
				text: "Research repository",
				href: "/pages/repository/",
				attributes: {
					property: "schema:item",
					typeof: "schema:Thing"
				}
			},
			{
				text: title
			}
		]
	}) }}

	<div class="govuk-grid-row">
		<div class="govuk-grid-column-two-thirds">
			<span class="govuk-caption-xl">Research repository</span>
			<h1 class="govuk-heading-xl">{{ title }}</h1>
			<p class="govuk-body-l">{{ lead }}</p>
			<p class="govuk-body">{{ body }}</p>
		</div>
	</div>

	{% if browseType %}
	<section class="repository-section" aria-labelledby="repository-browse-options-title" data-repository-browse-page data-browse-type="{{ browseType }}" data-browse-label="{{ browseLabel }}">
		<h2 class="govuk-heading-l" id="repository-browse-options-title">Choose {{ browseLabel | lower }}</h2>
		<p class="govuk-body">{{ browseHint }}</p>
		<div id="repository-browse-options" class="repository-browse-options" aria-live="polite" aria-busy="true"></div>
	</section>

	<section class="repository-section" aria-labelledby="repository-browse-results-title">
		<h2 class="govuk-heading-l" id="repository-browse-results-title">{{ resultsHeading or 'Published artefacts' }}</h2>
		<p class="govuk-body">{{ resultsIntro or 'Choose an option above to see published artefacts that match this route.' }}</p>
		<div class="govuk-inset-text repository-selected-state" id="repository-selected-state" hidden>
			<p class="govuk-body govuk-!-margin-bottom-1" id="repository-selected-summary"></p>
			<p class="govuk-body govuk-!-margin-bottom-0"><a class="govuk-link" href="/pages/repository/{{ slug }}/">Change {{ browseLabel | lower }}</a></p>
		</div>
		<form class="repository-sort-form" id="repository-sort-form" method="get" hidden>
			{{ govukSelect({
				id: 'repository-sort',
				name: 'sort',
				label: {
					text: 'Sort by',
					classes: 'govuk-label--s'
				},
				items: [
					{ value: 'reviewed_desc', text: 'Most recently reviewed' },
					{ value: 'confidence_desc', text: 'Highest confidence' },
					{ value: 'relevance', text: 'Most relevant' }
				]
			}) }}
			{{ govukButton({
				text: 'Apply sort',
				type: 'submit',
				classes: 'govuk-button--secondary'
			}) }}
		</form>
		<p class="repository-result-count" id="repository-browse-result-count" aria-live="polite"></p>
		<div id="repository-browse-results" class="repository-results" aria-live="polite" aria-busy="false">
			<div class="govuk-inset-text">Choose {{ browseLabel | lower }} to see published artefacts tagged to that {{ browseLabel | lower }}.</div>
		</div>
		<nav class="govuk-pagination repository-pagination" id="repository-pagination" aria-label="Repository result pages" hidden></nav>
	</section>
	{% elif candidateRoute %}
	<section class="repository-section" aria-labelledby="repository-candidate-title" data-repository-candidate-page>
		<h2 class="govuk-heading-l" id="repository-candidate-title">Candidate details</h2>
		<p class="govuk-body">Create a candidate record from reviewed evidence. The record is held in the publication queue until a curator confirms PII clearance, consent scope, confidence and reuse boundaries.</p>
		<form class="repository-candidate-form" id="repository-candidate-form" method="post" action="/api/repository/artefacts" novalidate>
			<div class="govuk-grid-row">
				<div class="govuk-grid-column-two-thirds">
					<div class="govuk-form-group">
						<label class="govuk-label govuk-label--s" for="candidate-title">Artefact title</label>
						<input class="govuk-input" id="candidate-title" name="title" type="text" autocomplete="off" required>
					</div>
					<div class="govuk-form-group">
						<label class="govuk-label govuk-label--s" for="candidate-summary">Reusable evidence summary</label>
						<textarea class="govuk-textarea" id="candidate-summary" name="summary" rows="5" required></textarea>
					</div>
					<div class="govuk-form-group">
						<label class="govuk-label govuk-label--s" for="candidate-limitations">Limitations</label>
						<textarea class="govuk-textarea" id="candidate-limitations" name="limitations" rows="4"></textarea>
					</div>
					<div class="govuk-form-group">
						<label class="govuk-label govuk-label--s" for="candidate-reuse-guidance">Reuse guidance</label>
						<textarea class="govuk-textarea" id="candidate-reuse-guidance" name="reuseGuidance" rows="4"></textarea>
					</div>
					<div class="govuk-form-group">
						<label class="govuk-label govuk-label--s" for="candidate-do-not-use-for">Do not use for</label>
						<textarea class="govuk-textarea" id="candidate-do-not-use-for" name="doNotUseFor" rows="4"></textarea>
					</div>
				</div>
				<div class="govuk-grid-column-one-third">
					<div class="repository-filter-panel">
						<div class="govuk-form-group">
							<label class="govuk-label govuk-label--s" for="candidate-service-area">Service area</label>
							<select class="govuk-select" id="candidate-service-area" name="serviceArea"></select>
						</div>
						<div class="govuk-form-group">
							<label class="govuk-label govuk-label--s" for="candidate-user-group">User group</label>
							<select class="govuk-select" id="candidate-user-group" name="userGroup"></select>
						</div>
						<div class="govuk-form-group">
							<label class="govuk-label govuk-label--s" for="candidate-method">Research method</label>
							<select class="govuk-select" id="candidate-method" name="method"></select>
						</div>
						<div class="govuk-form-group">
							<label class="govuk-label govuk-label--s" for="candidate-risk-area">Risk or constraint</label>
							<select class="govuk-select" id="candidate-risk-area" name="riskArea"></select>
						</div>
					</div>
				</div>
			</div>
			<section class="repository-section" aria-labelledby="repository-candidate-source-title">
				<h3 class="govuk-heading-m" id="repository-candidate-source-title">Source evidence</h3>
				<div class="govuk-grid-row">
					<div class="govuk-grid-column-one-half">
						<div class="govuk-form-group">
							<label class="govuk-label govuk-label--s" for="candidate-source-project-id">Source project</label>
							<select class="govuk-select" id="candidate-source-project-id" name="sourceProjectId">
								<option value="">Loading projects</option>
							</select>
						</div>
						<div class="govuk-form-group">
							<label class="govuk-label govuk-label--s" for="candidate-source-study-id">Source study</label>
							<input class="govuk-input" id="candidate-source-study-id" name="sourceStudyId" type="text" autocomplete="off">
						</div>
					</div>
					<div class="govuk-grid-column-one-half">
						<div class="govuk-form-group">
							<label class="govuk-label govuk-label--s" for="candidate-evidence-type">Evidence type</label>
							<select class="govuk-select" id="candidate-evidence-type" name="evidenceType">
								<option value="">Select evidence type</option>
								<option value="reviewed-synthesis">Reviewed synthesis</option>
								<option value="research-finding">Research finding</option>
								<option value="service-pattern">Service pattern</option>
								<option value="content-pattern">Content pattern</option>
								<option value="recommendation">Recommendation</option>
								<option value="operational-risk">Operational risk</option>
							</select>
						</div>
						<div class="govuk-form-group">
							<label class="govuk-label govuk-label--s" for="candidate-evidence-basis">Evidence basis</label>
							<textarea class="govuk-textarea" id="candidate-evidence-basis" name="sampleSummary" rows="4"></textarea>
						</div>
					</div>
				</div>
			</section>
			<section class="repository-section" aria-labelledby="repository-candidate-gates-title">
				<h3 class="govuk-heading-m" id="repository-candidate-gates-title">Publication gate</h3>
				<div class="govuk-inset-text">This submission creates a candidate only. It will not be published until PII clearance, consent-scope confirmation and curator review are complete.</div>
				<button class="govuk-button" data-module="govuk-button" type="submit">Submit for repository review</button>
				<div id="repository-candidate-status" aria-live="polite"></div>
			</section>
		</form>
	</section>
	{% endif %}

	{% if detailRoute %}
	<section class="repository-section" aria-labelledby="repository-artefact-detail-title">
		<h2 class="govuk-heading-l" id="repository-artefact-detail-title">{{ detailHeading or title }}</h2>
		<div id="repository-artefact-detail" aria-live="polite" aria-busy="true">
			<p class="govuk-body">Select an artefact from published repository results to view its detail.</p>
		</div>
	</section>
	{% endif %}

	{% for section in sections %}
	<section class="repository-section" aria-labelledby="repository-static-section-{{ loop.index }}">
		<h2 class="govuk-heading-l" id="repository-static-section-{{ loop.index }}">{{ section.heading }}</h2>
		<ul class="govuk-list govuk-list--bullet">
			{% for item in section.items %}
			<li>{{ item }}</li>
			{% endfor %}
		</ul>
	</section>
	{% endfor %}
</div>
{% endblock %}

{% block scripts %}
	{% if detailRoute %}
	<script type="module" src="/js/repository-artefact-page.js?v=repository-api-20260607b"></script>
	{% endif %}
	{% if browseType or candidateRoute %}
	<script type="module" src="/js/repository-static-page.js?v=repository-api-20260607b"></script>
	{% endif %}
{% endblock %}
