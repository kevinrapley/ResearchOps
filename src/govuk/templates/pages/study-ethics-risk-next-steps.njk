{% extends "layouts/researchops.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "macros/daas-brand-panel.njk" import daasBrandPanel %}

{% set ethicsRiskNextStepsScriptVersion = "study-ethics-risk-next-steps-20260704-17" %}

{% block head %}
	<meta property="schema:name" content="Ethics risk next steps - ResearchOps">
	<meta property="schema:creator" content="Home Office ResearchOps Platform">
	<meta property="schema:dateModified" content="2026-07-04">
	<meta property="dcterms:language" content="en-GB">
	<link rel="stylesheet" href="/css/govuk/govuk-forms.css" media="screen">
	<link rel="stylesheet" href="/css/sourcebook-components.css" media="screen">
	<link rel="stylesheet" href="/css/study-ethics-risk.css" media="screen">
	<link rel="stylesheet" href="/css/daas-brand-panel.css?v=leds-brand-panel-20260624" media="screen">
	<link rel="modulepreload" href="/js/study-route-context.js">
	<link rel="modulepreload" href="/js/study-ethics-risk-model.js?v=study-ethics-risk-20260704-2">
	<link rel="modulepreload" href="/js/study-ethics-risk-next-steps-page.js?v={{ ethicsRiskNextStepsScriptVersion }}">
	<link rel="modulepreload" href="/js/daas-brand-panel.js?v=leds-brand-panel-20260624">
{% endblock %}

{% block content %}
<div class="govuk-width-container study-ethics-risk-page study-ethics-risk-next-steps-page" data-study-subpage-template="ethics-risk-next-steps">
	{{ govukBreadcrumbs({
		attributes: {
			id: "study-ethics-risk-next-steps-breadcrumbs",
			typeof: "schema:BreadcrumbList"
		},
		items: [
			{ text: "Projects", href: "/pages/projects/" },
			{ text: "Project", href: "#", attributes: { id: "breadcrumb-project" } },
			{ text: "Study", href: "#", attributes: { id: "breadcrumb-study" } },
			{ text: "Ethics and research risk", href: "#", attributes: { id: "breadcrumb-ethics-risk" } },
			{ text: "Next steps" }
		]
	}) }}

	{{ daasBrandPanel() }}

	{{ govukErrorSummary({
		attributes: {
			id: "ethics-next-steps-error",
			tabindex: "-1",
			hidden: "hidden",
			"aria-hidden": "true"
		},
		titleText: "There is a problem",
		errorList: [
			{
				text: "Complete the ethics and research risk assessment first.",
				href: "#back-to-risk-assessment"
			}
		]
	}) }}

	<div id="study-context-warning" class="govuk-warning-text" hidden>
		<span class="govuk-warning-text__icon" aria-hidden="true">!</span>
		<strong class="govuk-warning-text__text">
			<span class="govuk-visually-hidden">Warning</span>
			Study details could not be loaded. The next steps can still be previewed locally for this study ID.
		</strong>
	</div>

	<header class="study-ethics-risk-header govuk-!-margin-bottom-7">
		<p id="study-eyebrow" class="govuk-caption-m">Study</p>
		<h1 id="ethics-next-steps-title" class="govuk-heading-l">Ethics risk next steps</h1>
		<p id="ethics-next-steps-summary" class="govuk-body-l govuk-!-width-two-thirds">Review the recorded ethics and research risk outcome, then complete the route-specific steps before recruitment, fieldwork or participant sessions begin.</p>
	</header>

	<div class="govuk-grid-row">
		<div class="govuk-grid-column-two-thirds">
			<section class="study-ethics-next-steps-panel govuk-!-margin-bottom-7" aria-labelledby="ethics-next-steps-task-title">
				<h2 id="ethics-next-steps-task-title" class="govuk-heading-m">What happens next</h2>
				<ol id="ethics-next-steps-list" class="govuk-task-list study-ethics-next-steps-list">
					<li class="govuk-task-list__item govuk-task-list__item--with-link">
						<div class="govuk-task-list__name-and-hint">
							<a class="govuk-link govuk-task-list__link" href="#back-to-risk-assessment">Complete the ethics and research risk assessment</a>
							<div class="govuk-task-list__hint">Answer the risk discovery questions and record the study risk outcome.</div>
						</div>
						<div class="govuk-task-list__status"><strong class="govuk-tag govuk-tag--yellow">Action needed</strong></div>
					</li>
				</ol>
			</section>

			<section class="study-ethics-next-steps-panel govuk-!-margin-bottom-7" aria-labelledby="ethics-next-steps-evidence-title">
				<h2 id="ethics-next-steps-evidence-title" class="govuk-heading-m">Evidence to collect</h2>
				<p id="ethics-next-steps-evidence-intro" class="govuk-body">Evidence depends on the recorded risk route.</p>
				<ul id="ethics-next-steps-evidence-list" class="govuk-list govuk-list--bullet">
					<li>Risk assessment outcome</li>
					<li>Triage outcome</li>
				</ul>
			</section>

			<section id="ethics-next-steps-action" class="study-ethics-next-steps-panel govuk-!-margin-bottom-7" aria-labelledby="ethics-next-steps-action-title">
				<h2 id="ethics-next-steps-action-title" class="govuk-heading-m">Record checkpoint decision</h2>
				<p id="ethics-next-steps-action-intro" class="govuk-body">Complete and save the ethics and research risk assessment before recording route-specific checkpoint decisions.</p>
				<div id="ethics-next-step-route-state" class="study-ethics-next-steps-route-state govuk-!-margin-bottom-5">
					<h3 id="ethics-next-step-route-state-title" class="govuk-heading-s govuk-!-margin-bottom-1">Current next step</h3>
					<p id="ethics-next-step-route-state-summary" class="govuk-body">Risk assessment needs to be completed.</p>
				</div>

				<section id="ethics-submission-workflow" class="study-ethics-submission-workflow" aria-labelledby="ethics-submission-workflow-title" hidden>
					<p class="govuk-caption-m">Full ethics submission</p>
					<h3 id="ethics-submission-workflow-title" class="govuk-heading-m">Prepare ethics submission version 1</h3>
					<p id="ethics-submission-workflow-summary" class="govuk-body">Work through each section, save progress and return later if needed.</p>

					<dl class="govuk-summary-list study-ethics-submission-meta">
						<div class="govuk-summary-list__row">
							<dt class="govuk-summary-list__key">Submission type</dt>
							<dd id="ethics-submission-type" class="govuk-summary-list__value">System determined</dd>
						</div>
						<div class="govuk-summary-list__row">
							<dt class="govuk-summary-list__key">Current version</dt>
							<dd id="ethics-submission-version" class="govuk-summary-list__value">Version 1</dd>
						</div>
						<div class="govuk-summary-list__row">
							<dt class="govuk-summary-list__key">Saved progress</dt>
							<dd id="ethics-submission-progress" class="govuk-summary-list__value">No sections saved yet.</dd>
						</div>
					</dl>

					<ol id="ethics-submission-step-list" class="govuk-task-list study-ethics-submission-step-list"></ol>

					<div id="ethics-submission-step-error-summary" class="govuk-error-summary" data-module="govuk-error-summary" role="alert" tabindex="-1" hidden>
						<h2 class="govuk-error-summary__title">There is a problem</h2>
						<div class="govuk-error-summary__body">
							<ul class="govuk-list govuk-error-summary__list">
								<li>
									<a id="ethics-submission-step-error-link" href="#ethics-submission-step-input">Enter the missing information for this section</a>
								</li>
							</ul>
						</div>
					</div>

					<form id="ethics-submission-step-form" class="study-ethics-submission-step-form" novalidate>
						<p id="ethics-submission-step-caption" class="govuk-caption-m">Step 1 of 1</p>
						<h4 id="ethics-submission-step-title" class="govuk-heading-s">Submission section</h4>
						<p id="ethics-submission-step-hint" class="govuk-body">Review the information that will be included in this section.</p>
						<div class="study-ethics-submission-derived govuk-!-margin-bottom-5">
							<h5 class="govuk-heading-s">Generated from ResearchOps</h5>
							<div id="ethics-submission-step-derived" class="govuk-body">No generated content is available for this section.</div>
						</div>
						<div id="ethics-submission-step-input-group" class="govuk-form-group" hidden>
							<label id="ethics-submission-step-input-label" class="govuk-label govuk-label--s" for="ethics-submission-step-input">Provide missing information for this section</label>
							<div id="ethics-submission-step-input-hint" class="govuk-hint">Only add information needed for ethics board review. Do not include participant personal data.</div>
							<p id="ethics-submission-step-input-error" class="govuk-error-message" hidden></p>
							<textarea class="govuk-textarea" id="ethics-submission-step-input" name="submissionStepInput" rows="6" aria-describedby="ethics-submission-step-input-hint"></textarea>
						</div>
						<div class="govuk-button-group">
							{{ govukButton({
								text: "Save and continue",
								type: "submit",
								attributes: {
									id: "ethics-submission-save-continue"
								}
							}) }}
							{{ govukButton({
								text: "Save and return later",
								type: "button",
								classes: "govuk-button--secondary",
								attributes: {
									id: "ethics-submission-save-later"
								}
							}) }}
						</div>
					</form>

					<div id="ethics-submission-submit-panel" class="study-ethics-submission-submit-panel govuk-!-margin-top-6" hidden>
						<h4 id="ethics-submission-submit-title" class="govuk-heading-s">Submit this version</h4>
						<p id="ethics-submission-submit-summary" class="govuk-body">Submit the saved ethics pack and attachments when every section is ready for board review.</p>
						<p id="ethics-submission-document-status" class="govuk-body-s study-ethics-submission-document-status" role="status"></p>
						<div class="govuk-button-group">
							{{ govukButton({
								text: "Submit ethics submission",
								type: "button",
								attributes: {
									id: "ethics-submission-submit-version"
								}
							}) }}
							{{ govukButton({
								text: "Create resubmission",
								type: "button",
								classes: "govuk-button--secondary",
								attributes: {
									id: "ethics-submission-create-resubmission"
								}
							}) }}
						</div>
					</div>

					<section class="study-ethics-submission-history govuk-!-margin-top-6" aria-labelledby="ethics-submission-history-title">
						<h4 id="ethics-submission-history-title" class="govuk-heading-s">Submission history</h4>
						<p id="ethics-submission-history-empty" class="govuk-body">No submission versions have been sent yet.</p>
						<ol id="ethics-submission-history-list" class="govuk-list govuk-list--number"></ol>
					</section>
				</section>

				<form id="ethics-next-steps-form" novalidate hidden>
					<dl id="ethics-next-step-assignment" class="govuk-summary-list study-ethics-next-steps-assignment">
						<div class="govuk-summary-list__row">
							<dt id="ethics-next-step-owner-label" class="govuk-summary-list__key">Owner of the next action</dt>
							<dd id="ethics-next-step-owner-value" class="govuk-summary-list__value">Research Operations</dd>
						</div>
						<div class="govuk-summary-list__row">
							<dt id="ethics-next-step-reviewer-label" class="govuk-summary-list__key">Reviewer or approver</dt>
							<dd id="ethics-next-step-reviewer-value" class="govuk-summary-list__value">Research Operations</dd>
						</div>
						<div class="govuk-summary-list__row">
							<dt id="ethics-next-step-review-date-label" class="govuk-summary-list__key">Expected review date</dt>
							<dd id="ethics-next-step-review-date-value" class="govuk-summary-list__value">Calculated after the checkpoint record is saved.</dd>
						</div>
					</dl>

					<section id="ethics-next-step-review-context" class="study-ethics-next-steps-review-context govuk-!-margin-bottom-6" aria-labelledby="ethics-next-step-review-context-title" hidden>
						<h3 id="ethics-next-step-review-context-title" class="govuk-heading-s">Context to send to reviewers</h3>
						<p id="ethics-next-step-review-context-intro" class="govuk-body">Use the saved ethics and research risk assessment as context for the advice request.</p>
						<dl class="govuk-summary-list">
							<div class="govuk-summary-list__row">
								<dt class="govuk-summary-list__key">Sensitive research triggers</dt>
								<dd id="ethics-next-step-review-triggers" class="govuk-summary-list__value">No sensitive research triggers recorded.</dd>
							</div>
							<div class="govuk-summary-list__row">
								<dt class="govuk-summary-list__key">Controls to include</dt>
								<dd id="ethics-next-step-review-controls" class="govuk-summary-list__value">No additional controls recorded.</dd>
							</div>
						</dl>
					</section>

						<div class="govuk-form-group">
							<label id="ethics-next-step-request-label" class="govuk-label govuk-label--s" for="ethics-next-step-request">Advice question, controls or submission contents</label>
							<textarea class="govuk-textarea" id="ethics-next-step-request" name="nextStepRequest" rows="5"></textarea>
						</div>

						<div id="ethics-next-step-submission-fields" class="study-ethics-next-steps-submission-fields govuk-!-margin-bottom-6" hidden></div>

						<div id="ethics-next-step-decision-group" class="govuk-form-group">
							<label id="ethics-next-step-decision-label" class="govuk-label govuk-label--s" for="ethics-next-step-decision">Decision, controls or conditions</label>
							<div class="govuk-hint">Do not include participant personal data.</div>
						<textarea class="govuk-textarea" id="ethics-next-step-decision" name="nextStepDecision" rows="6"></textarea>
					</div>

					<div class="govuk-button-group">
						{{ govukButton({
							text: "Save checkpoint record",
							type: "submit",
							attributes: {
								id: "ethics-next-steps-submit"
							}
						}) }}
						{{ govukButton({
							text: "Back to study",
							href: "/pages/study/",
							classes: "govuk-button--secondary",
							attributes: {
								id: "back-to-study"
							}
						}) }}
					</div>
				</form>
				<p id="ethics-next-steps-recorded-state" class="govuk-body-s study-ethics-risk-recorded-state">No checkpoint decision recorded yet.</p>
			</section>
		</div>

		<aside class="govuk-grid-column-one-third study-ethics-risk-aside" aria-labelledby="ethics-next-steps-outcome-title">
			<section class="study-ethics-risk-outcome" aria-live="polite">
				<p class="govuk-caption-m">Recorded risk route</p>
				<h2 id="ethics-next-steps-outcome-title" class="govuk-heading-m">Risk assessment needed</h2>
				<strong id="ethics-next-steps-outcome-tag" class="govuk-tag govuk-tag--yellow">Action needed</strong>
				<p id="ethics-next-steps-outcome-summary" class="govuk-body">Complete the ethics and research risk assessment to see the route-specific next steps.</p>
				<h3 class="govuk-heading-s">Sensitive research triggers</h3>
				<div id="ethics-next-steps-triggers" class="study-ethics-risk-trigger-groups">
					<p class="govuk-body">No sensitive research triggers are shown until the risk outcome is recorded.</p>
				</div>
				<h3 class="govuk-heading-s">Sourcebook clauses</h3>
				<p id="ethics-next-steps-sourcebook-clauses" class="govuk-body">Sourcebook clauses appear after the risk outcome is recorded.</p>
				<p class="govuk-body-s"><a id="back-to-risk-assessment" class="govuk-link" href="/pages/study/ethics-risk/">Review risk assessment</a></p>
			</section>
		</aside>
	</div>
</div>
{% endblock %}

{% block scripts %}
	<script type="module" src="/js/daas-brand-panel.js?v=leds-brand-panel-20260624"></script>
	<script type="module" src="/js/study-ethics-risk-next-steps-page.js?v={{ ethicsRiskNextStepsScriptVersion }}"></script>
{% endblock %}
