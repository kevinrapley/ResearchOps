{% extends "layouts/researchops.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "macros/daas-brand-panel.njk" import daasBrandPanel %}

{% set studyPageScriptVersion = "study-record-id-routing-20260518" %}

{% block head %}
	<meta property="schema:name" content="Study participants - ResearchOps">
	<link rel="stylesheet" href="/css/govuk/govuk-forms.css" media="screen">
	<link rel="stylesheet" href="/css/govuk/govuk-tables.css" media="screen">
	<link rel="stylesheet" href="/css/participants.css" media="screen">
	<link rel="stylesheet" href="/css/daas-brand-panel.css?v=leds-brand-panel-20260624" media="screen">
	<link rel="modulepreload" href="/js/study-route-context.js">
	<link rel="modulepreload" href="/js/daas-brand-panel.js?v=leds-brand-panel-20260624">
	<link rel="modulepreload" href="/js/participants-route-loader.js?v={{ studyPageScriptVersion }}">
	<!-- route-state contract: src="/components/participants/participants-page.js" defer -->
	<!-- route-state contract: src="/pages/study/participants/scheduler.js" defer -->
{% endblock %}

{% block content %}
<div class="govuk-width-container study-participants-page" data-study-subpage-template="participants">
	{{ govukBreadcrumbs({
		attributes: {
			id: "study-participants-breadcrumbs",
			typeof: "schema:BreadcrumbList"
		},
		items: [
			{
				text: "Projects",
				href: "/pages/projects/",
				attributes: {
					property: "schema:item",
					typeof: "schema:Thing"
				}
			},
			{
				text: "Project",
				href: "#",
				attributes: {
					id: "breadcrumb-project",
					property: "schema:item",
					typeof: "schema:Thing"
				}
			},
			{
				text: "Study",
				href: "#",
				attributes: {
					id: "breadcrumb-study",
					property: "schema:item",
					typeof: "schema:Thing"
				}
			},
			{ text: "Participants" }
		]
	}) }}

	{{ daasBrandPanel() }}

	<header class="govuk-!-margin-bottom-7">
		<p id="studyBadge" class="govuk-caption-m">Study</p>
		<h1 class="govuk-heading-l">Participants</h1>
		<p class="govuk-body govuk-!-width-two-thirds">Add participants, review restricted contact details and schedule sessions for this study.</p>
	</header>

	<section class="participants-section" aria-labelledby="participants-h">
		<h2 id="participants-h" class="govuk-heading-m">Participants in this study</h2>
		<p class="govuk-body govuk-!-width-two-thirds">Review who is available for fieldwork. Contact details stay restricted until they are explicitly revealed.</p>

		<div id="participantsEmpty" class="govuk-inset-text" hidden>
			<h3 class="govuk-heading-s govuk-!-margin-bottom-2">No participants yet</h3>
			<p class="govuk-body">Add your first participant to begin scheduling sessions.</p>
			{{ govukButton({ text: "Add a participant", href: "#addParticipantForm" }) }}
		</div>

		<div class="table-wrap" id="participantsTableWrap" hidden>
			<table id="participantsTable" class="govuk-table" aria-label="Participants">
				<thead class="govuk-table__head">
					<tr class="govuk-table__row">
						<th scope="col" class="govuk-table__header">Participant reference</th>
						<th scope="col" class="govuk-table__header">Contact details</th>
						<th scope="col" class="govuk-table__header">Status</th>
						<th scope="col" class="govuk-table__header"><span class="govuk-visually-hidden">Actions</span></th>
					</tr>
				</thead>
				<tbody id="participants-tbody" class="govuk-table__body">
					<tr class="govuk-table__row">
						<td colspan="4" class="govuk-table__cell muted">Loading...</td>
					</tr>
				</tbody>
			</table>
		</div>
	</section>

	<section class="participants-section participants-section--form" aria-labelledby="addp-h">
		<div class="govuk-grid-row">
			<div class="govuk-grid-column-two-thirds">
				<h2 id="addp-h" class="govuk-heading-m govuk-!-margin-bottom-3">Add participant</h2>
				<p class="govuk-body">Add a participant to this study so the team can manage recruitment, consent, withdrawal and sessions.</p>

				{{ govukInsetText({
					html: '<h3 class="govuk-heading-s">How participant details are used</h3><p class="govuk-body">Real names and contact details are used for recruitment, consent and withdrawal operations.</p><p class="govuk-body">Participant lists continue to show the participant reference by default. Real names, contact details and support needs are restricted to authorised project roles.</p>'
				}) }}

				<form id="addParticipantForm" class="form" novalidate>
					<input id="p_project_id" name="project_id" type="hidden" value="">
					<input id="p_study_id" name="study_id" type="hidden" value="">

					<h3 class="govuk-heading-s">Participant identity</h3>
					{{ govukInput({
						id: "p_first_name",
						name: "first_name",
						classes: "govuk-!-width-two-thirds",
						label: { text: "First name" },
						hint: { text: "Enter the participant’s real first name so the research team can manage recruitment, consent and withdrawal correctly." },
						autocomplete: "given-name",
						attributes: { required: "required" }
					}) }}

					{{ govukInput({
						id: "p_family_name",
						name: "family_name",
						classes: "govuk-!-width-two-thirds",
						label: { text: "Family name" },
						hint: { text: "Enter the participant’s real family name." },
						autocomplete: "family-name",
						attributes: { required: "required" }
					}) }}

					{{ govukInput({
						id: "p_participant_ref",
						name: "participant_ref",
						classes: "govuk-!-width-two-thirds",
						label: { text: "Participant reference (optional)" },
						hint: { text: "This is the label shown by default in participant lists. Do not use a real name here. Leave blank to let ResearchOps create one." },
						autocomplete: "off"
					}) }}

					<h3 class="govuk-heading-s">Contact details</h3>
					{{ govukInput({
						id: "p_email",
						name: "email",
						type: "email",
						classes: "govuk-!-width-two-thirds",
						label: { text: "Email address (optional)" },
						autocomplete: "email"
					}) }}

					{{ govukInput({
						id: "p_phone",
						name: "phone",
						type: "tel",
						classes: "govuk-!-width-two-thirds",
						label: { text: "Phone number (optional)" },
						autocomplete: "tel"
					}) }}

					{{ govukCheckboxes({
						idPrefix: "p_channel",
						name: "channel_pref",
						fieldset: {
							legend: {
								text: "Preferred contact methods",
								classes: "govuk-fieldset__legend--s"
							}
						},
						hint: {
							text: "Select all contact methods the participant prefers."
						},
						items: [
							{ value: "email", text: "Email", checked: true },
							{ value: "sms", text: "Text message" },
							{ value: "phone", text: "Phone call" }
						]
					}) }}

					<h3 class="govuk-heading-s">Access or support needs</h3>
					{{ govukTextarea({
						id: "p_access",
						name: "access_needs",
						classes: "govuk-!-width-two-thirds",
						value: "",
						rows: 4,
						label: { text: "Access or support needs (optional)" },
						hint: { text: "Only include adjustments or support needs needed to plan and run the session. Do not record medical history or unnecessary personal details." }
					}) }}

					<div class="form__actions">
						{{ govukButton({ text: "Create participant", type: "submit" }) }}
						<span id="addParticipantMsg" class="msg" role="status" aria-live="polite"></span>
					</div>
				</form>
			</div>
			<div class="govuk-grid-column-one-third">
				{{ govukDetails({
					summaryText: "What happens next",
					html: '<p class="govuk-body">ResearchOps creates a participant record and links it to this study.</p><p class="govuk-body">This does not send an email, create a consent request or schedule a session. Those actions happen separately from this page.</p>'
				}) }}
			</div>
		</div>
	</section>

	<section class="participants-section" aria-labelledby="sessions-h">
		<h2 id="sessions-h" class="govuk-heading-m govuk-!-margin-bottom-3">Scheduled sessions</h2>
		<p class="govuk-body govuk-!-width-two-thirds">Review sessions that have been scheduled for participants in this study.</p>

		<div id="sessionsEmpty" class="govuk-inset-text" hidden>
			<h3 class="govuk-heading-s govuk-!-margin-bottom-2">No sessions yet</h3>
			<p class="govuk-body">Schedule a session once you have added at least one participant.</p>
			{{ govukButton({ text: "Schedule a session", href: "#scheduleForm", attributes: { id: "scheduleCta" } }) }}
		</div>

		<div class="table-wrap" id="sessionsTableWrap" hidden>
			<table id="sessionsTable" class="govuk-table" aria-label="Sessions">
				<thead class="govuk-table__head">
					<tr class="govuk-table__row">
						<th scope="col" class="govuk-table__header">When</th>
						<th scope="col" class="govuk-table__header">Participant</th>
						<th scope="col" class="govuk-table__header">Status</th>
						<th scope="col" class="govuk-table__header"><span class="govuk-visually-hidden">Actions</span></th>
					</tr>
				</thead>
				<tbody id="sessions-tbody" class="govuk-table__body"></tbody>
			</table>
		</div>
	</section>

	<section class="participants-section participants-section--form" aria-labelledby="schedules-h">
		<div class="govuk-grid-row">
			<div class="govuk-grid-column-two-thirds">
				<h2 id="schedules-h" class="govuk-heading-m govuk-!-margin-bottom-3">Schedule a session</h2>
				<p class="govuk-body">Choose the participant, date, time and session details. Scheduling is enabled when the study has at least one session-compatible participant record.</p>

				<div id="noParticipantsBanner" class="govuk-inset-text" role="status" hidden>
					Add at least one participant to enable scheduling.
				</div>

				<form id="scheduleForm" class="form" novalidate>
					<div class="govuk-grid-row">
						<div class="govuk-grid-column-one-half">
							<div class="govuk-form-group">
								<label class="govuk-label" for="s_participant">Participant</label>
								<select class="govuk-select" id="s_participant" required></select>
							</div>
						</div>
						<div class="govuk-grid-column-one-half">
							{{ govukSelect({
								id: "s_type",
								name: "sessionType",
								label: { text: "Session type" },
								items: [
									{ value: "remote", text: "Remote", selected: true },
									{ value: "in-person", text: "In person" }
								]
							}) }}
						</div>
					</div>

					{{ govukDateInput({
						id: "s_date",
						namePrefix: "s_date",
						fieldset: {
							legend: {
								text: "Start date",
								classes: "govuk-fieldset__legend--s"
							}
						},
						hint: {
							text: "For example, 27 3 2026"
						}
					}) }}

					<div class="govuk-form-group">
						<fieldset class="govuk-fieldset" role="group" aria-describedby="s_time-hint">
							<legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Start time</legend>
							<div id="s_time-hint" class="govuk-hint">Use 24-hour time, for example 14 30.</div>
							<div class="participants-time-inputs">
								{{ govukInput({
									id: "s_time-hour",
									name: "s_time_hour",
									classes: "govuk-input--width-2",
									label: { text: "Hour", classes: "govuk-label--s" },
									inputmode: "numeric",
									attributes: { pattern: "[0-9]*", required: "required" }
								}) }}

								{{ govukInput({
									id: "s_time-minute",
									name: "s_time_minute",
									classes: "govuk-input--width-2",
									label: { text: "Minute", classes: "govuk-label--s" },
									inputmode: "numeric",
									attributes: { pattern: "[0-9]*", required: "required" }
								}) }}
							</div>
						</fieldset>
					</div>

					<div class="govuk-grid-row">
						<div class="govuk-grid-column-one-half">
							{{ govukInput({
								id: "s_duration",
								name: "duration",
								type: "number",
								value: "60",
								label: { text: "Duration in minutes" },
								attributes: { min: "15", step: "5", required: "required" }
							}) }}
						</div>
					</div>

					{{ govukInput({
						id: "s_location",
						name: "location",
						classes: "govuk-!-width-two-thirds",
						label: { text: "Location or joining link" },
						attributes: { required: "required" }
					}) }}

					<div class="govuk-grid-row">
						<div class="govuk-grid-column-one-half">
							{{ govukInput({
								id: "s_backup",
								name: "backupContact",
								label: { text: "Backup contact" }
							}) }}
						</div>
						<div class="govuk-grid-column-one-half">
							{{ govukInput({
								id: "s_researchers",
								name: "researchers",
								label: { text: "Researchers" }
							}) }}
						</div>
					</div>

					{{ govukTextarea({
						id: "s_notes",
						name: "notes",
						classes: "govuk-!-width-two-thirds",
						value: "",
						rows: 4,
						label: { text: "Notes" }
					}) }}

					<div class="form__actions">
						{{ govukButton({
							text: "Create session",
							type: "submit",
							attributes: { id: "scheduleBtn" }
						}) }}
						<span id="scheduleMsg" class="msg" role="status" aria-live="polite"></span>
					</div>
				</form>
			</div>
			<div class="govuk-grid-column-one-third">
				{{ govukInsetText({
					text: "Scheduled sessions appear in the sessions table. Download the calendar file after creating a session."
				}) }}
			</div>
		</div>
	</section>
</div>
{% endblock %}

{% block scripts %}
	<script type="module" src="/js/daas-brand-panel.js?v=leds-brand-panel-20260624"></script>
	<script type="module" src="/js/participants-route-loader.js?v={{ studyPageScriptVersion }}"></script>
{% endblock %}
