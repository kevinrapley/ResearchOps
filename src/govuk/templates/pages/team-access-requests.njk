{% extends "layouts/researchops.njk" %}

{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block content %}
<div class="govuk-width-container">
	{{ govukBreadcrumbs({
		items: [
			{
				text: 'Home',
				href: '/'
			},
			{
				text: 'Your account',
				href: '/pages/account/'
			}
		]
	}) }}

	<div class="govuk-grid-row">
		<div class="govuk-grid-column-two-thirds">
			<span class="govuk-caption-l">Team administration</span>
			<h1 class="govuk-heading-xl">Review team access requests</h1>
			<p class="govuk-body-l">Approve or reject requests from people who want to join a team you administer.</p>
			<p class="govuk-body">Approving a request makes the person a team member. It does not give them a role or access to sensitive information.</p>

			{{ govukWarningText({
				text: 'Only approve a request when you are confident the person should become a member of the team. Assign roles separately after approval.',
				iconFallbackText: 'Warning'
			}) }}
		</div>
	</div>

	{{ govukErrorSummary({
		titleText: 'There is a problem',
		errorList: [],
		attributes: {
			id: 'team-access-review-error-summary',
			hidden: 'hidden'
		}
	}) }}

	<section aria-labelledby="team-access-review-loading-title" id="team-access-review-loading">
		<h2 class="govuk-heading-m" id="team-access-review-loading-title">Checking team access requests</h2>
		<p class="govuk-body">ResearchOps is checking for pending requests you can review.</p>
	</section>

	<section aria-labelledby="team-access-review-empty-title" id="team-access-review-empty" hidden>
		<h2 class="govuk-heading-m" id="team-access-review-empty-title">There are no team access requests to review.</h2>
		<p class="govuk-body">Requests that need your decision will appear here.</p>
	</section>

	<section aria-labelledby="team-access-review-pending-title" id="team-access-review-pending" hidden>
		<h2 class="govuk-heading-m" id="team-access-review-pending-title">Pending requests</h2>
		<div id="team-access-review-list"></div>
	</section>
</div>
{% endblock %}

{% block scripts %}
<script type="module" src="/js/auth-team-access-review-page.js?v=team-access-review-20260531"></script>
{% endblock %}
