{
  "name": "researchops-sdk",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "prettier -c . && eslint .",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "validate": "bash ./scripts/validate.sh",
    "audit:performance": "bash ./scripts/performance-audit.sh",
    "audit:performance:write": "bash ./scripts/performance-audit.sh --write docs/performance/performance-inventory.md",
    "audit:security": "bash ./scripts/security-audit-policy.sh",
    "test": "node --test",
    "test:e2e": "playwright test",
    "qa:browsers": "playwright install chromium",
    "qa:cucumber": "cucumber-js -p default",
    "qa:cucumber:ci": "cucumber-js -p default",
    "qa:cucumber:walkthrough": "BDD_CAPTURE_SCREENSHOTS=true cucumber-js -p default"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@eslint/js": "^9.12.0",
    "@playwright/test": "^1.56.1",
    "ajv": "^8.17.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^14.0.0",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
